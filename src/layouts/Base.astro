---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import { withBase } from '../config/apps';

interface Props {
  title: string;
  description: string;
  /** App Store ID → renders the Apple Smart Banner meta */
  appStoreId?: string;
  /** root-relative og image path (public/) or absolute URL */
  ogImage?: string;
  bodyClass?: string;
  activeApp?: string;
  jsonLd?: object | object[];
}

const { title, description, appStoreId, ogImage, bodyClass = '', activeApp, jsonLd } = Astro.props;

const canonical = new URL(Astro.url.pathname.replace(import.meta.env.BASE_URL, '/').replace('//', '/'), Astro.site);
const ogImageUrl = ogImage
  ? ogImage.startsWith('http')
    ? ogImage
    : new URL(ogImage, Astro.site).href
  : new URL('/icons/sofia.jpg', Astro.site).href;
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <Analytics />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" type="image/jpeg" href={withBase('/icons/sofia.jpg')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    {appStoreId && <meta name="apple-itunes-app" content={`app-id=${appStoreId}`} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Bliss Coach" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class={bodyClass}>
    <div class="page">
      <Header activeApp={activeApp} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
    <script>
      // Progressive scroll-reveal: elements start visible for no-JS / reduced
      // motion; only when motion is allowed do we hide then fade them in.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const els = document.querySelectorAll(
          '.feature, .article-card, .section > h2, .section > .lead, .app-hero .kicker, .app-hero h1, .app-hero p.sub',
        );
        els.forEach((el) => {
          el.classList.add('reveal');
          // small stagger among siblings for a cascading feel
          const i = Array.prototype.indexOf.call(el.parentElement?.children ?? [], el);
          (el as HTMLElement).style.transitionDelay = `${Math.min(i, 5) * 70}ms`;
        });
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

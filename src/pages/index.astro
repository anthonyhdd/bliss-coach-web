      @keyframes tile-glow { 0%, 100% { box-shadow: 0 10px 24px rgba(0, 0, 0, 0.55); } 50% { box-shadow: 0 10px 24px rgba(0, 0, 0, 0.55), 0 0 18px rgba(255, 200, 180, 0.55); } }

      /* pocket: coaching energy radiating from your pocket */
      .pring {
        position: absolute; left: 50%; bottom: 12px; width: 20px; height: 20px; margin-left: -10px;
        border-radius: 50%; border: 1.5px solid rgba(255, 220, 131, 0.55);
        opacity: 0; pointer-events: none;

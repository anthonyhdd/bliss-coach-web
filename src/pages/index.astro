    <script>
      // Home bootstrap — re-runs after every client-side navigation (ClientRouter).
      // A generation counter kills the previous visit's rAF loops, and an
      // AbortController detaches its window listeners, so re-entering the home
      // never double-binds anything.
      declare global {
        interface Window { __homeGen?: number; __homeAbort?: AbortController }
      }
      function initHome() {
      const canvas = document.getElementById('stars') as HTMLCanvasElement | null;
      if (!canvas) return; // navigated to a non-home page
      const gen = (window.__homeGen = (window.__homeGen || 0) + 1);
      const live = () => window.__homeGen === gen;
      window.__homeAbort?.abort();
      const ac = new AbortController();
      window.__homeAbort = ac;
      const L: AddEventListenerOptions = { signal: ac.signal };
      const ctx = canvas.getContext('2d')!;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let stars: { x: number; y: number; r: number; a: number; s: number; vx: number; vy: number }[] = [];

      function seed() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = canvas.offsetWidth * dpr;
        canvas.height = canvas.offsetHeight * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const n = Math.round((canvas.offsetWidth * canvas.offsetHeight) / 9000);
        stars = Array.from({ length: n }, () => ({
          x: Math.random() * canvas.offsetWidth,
          y: Math.random() * canvas.offsetHeight * 0.8,
          r: Math.random() * 1.1 + 0.4,
          a: Math.random() * 0.55 + 0.15,
          s: Math.random() * 0.004 + 0.001,
          vx: (Math.random() - 0.5) * 0.1,
          vy: -(Math.random() * 0.05 + 0.012),
        }));
      }

      let t = 0;
      function draw() {
        if (!live()) return;
        t++;
        ctx.clearRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);
        for (const st of stars) {
          if (!reduceMotion) {
            st.x += st.vx;
            st.y += st.vy;
            if (st.y < -2) { st.y = canvas.offsetHeight * 0.8 + 2; st.x = Math.random() * canvas.offsetWidth; }
            if (st.x < -2) st.x = canvas.offsetWidth + 2;
            else if (st.x > canvas.offsetWidth + 2) st.x = -2;
          }
          const tw = st.a + Math.sin(t * st.s * 60) * 0.18;
          ctx.globalAlpha = Math.max(0.05, Math.min(0.8, tw));
          ctx.beginPath();
          ctx.arc(st.x, st.y, st.r, 0, Math.PI * 2);
          ctx.fillStyle = '#ffffff';
          ctx.fill();
        }
        requestAnimationFrame(draw);
      }

      // occasional shooting star across the hero
      let shooting: { x: number; y: number; vx: number; vy: number; life: number } | null = null;
      if (!reduceMotion) {
        const shootId = setInterval(() => {
          if (!shooting && Math.random() < 0.6) {
            shooting = {
              x: Math.random() * canvas.offsetWidth * 0.7 + canvas.offsetWidth * 0.15,
              y: Math.random() * canvas.offsetHeight * 0.25,
              vx: 6 + Math.random() * 5,
              vy: 2.4 + Math.random() * 2,
              life: 1,
            };
          }
        }, 5000);
        ac.signal.addEventListener('abort', () => clearInterval(shootId));
      }
      seed();
      draw();
      window.addEventListener('resize', seed, L);

      // shooting star painter (separate rAF to keep the original loop untouched)
      function paintShooting() {
        if (!live()) return;
        if (shooting) {
          const s = shooting;
          ctx.save();
          ctx.globalAlpha = Math.max(s.life, 0) * 0.9;
          ctx.strokeStyle = '#fff';
          ctx.lineWidth = 1.6;
          ctx.beginPath();
          ctx.moveTo(s.x, s.y);
          ctx.lineTo(s.x - s.vx * 5, s.y - s.vy * 5);
          ctx.stroke();
          ctx.restore();
          s.x += s.vx; s.y += s.vy; s.life -= 0.022;
          if (s.life <= 0 || s.x > canvas.offsetWidth + 60) shooting = null;
        }
        requestAnimationFrame(paintShooting);
      }
      if (!reduceMotion) paintShooting();

      // pointer parallax: stars, nebula and the coach dock drift with the cursor
      if (!reduceMotion && matchMedia('(pointer: fine)').matches) {
        const nebula = document.querySelector('.nebula') as HTMLElement;
        const dock = document.querySelector('.avatars') as HTMLElement;
        const props = Array.from(document.querySelectorAll<HTMLElement>('.prop'));
        let tx = 0, ty = 0, cx = 0, cy = 0;
        window.addEventListener('mousemove', (e) => {
          tx = (e.clientX / window.innerWidth - 0.5);
          ty = (e.clientY / window.innerHeight - 0.5);
        }, { passive: true, signal: ac.signal });
        (function lerp() {
          if (!live()) return;
          cx += (tx - cx) * 0.06;
          cy += (ty - cy) * 0.06;
          canvas.style.transform = `translate(${cx * -14}px, ${cy * -8}px)`;
          if (nebula) nebula.style.transform = `translate(${cx * -26}px, ${cy * -14}px)`;
          if (dock) dock.style.transform = `translateX(calc(-50% + ${cx * 10}px))`;
          for (const pr of props) {
            const d = parseFloat(pr.dataset.depth || '0.8');
            pr.style.transform = `translate(${cx * d * 30}px, ${cy * d * 18}px)`;
          }
          requestAnimationFrame(lerp);
        })();
      }

      // hero content gently recedes as you scroll away
      if (!reduceMotion) {
        const heroContent = document.querySelector('.card .content') as HTMLElement;
        let hTick = false;
        window.addEventListener('scroll', () => {
          if (hTick) return;
          hTick = true;
          requestAnimationFrame(() => {
            hTick = false;
            const y = Math.min(window.scrollY, 700);
            heroContent.style.transform = `translateY(${y * 0.18}px)`;
            heroContent.style.opacity = String(1 - y / 900);
          });
        }, { passive: true, signal: ac.signal });
      }

      // coach chapter media: the standing loop plays by default; hovering
      // (or tapping) crossfades to the livelier idle loop.
      document.querySelectorAll<HTMLElement>('.chapter').forEach((card) => {
        const stand = card.querySelector<HTMLVideoElement>('.v-stand');
        const idle = card.querySelector<HTMLVideoElement>('.v-idle');
        if (!stand) return;
        // Reduced motion: no ambient autoplay, but hover/tap (an explicit
        // gesture) still brings the coach to life.
        if (reduceMotion) { stand.autoplay = false; stand.pause(); }
        const live = idle ?? stand;
        const on = () => { live.play().catch(() => {}); if (idle) card.classList.add('idle-on'); };
        const off = () => {
          card.classList.remove('idle-on');
          if (idle) setTimeout(() => idle.pause(), 400);
          else if (reduceMotion) stand.pause();
        };
        card.addEventListener('pointerenter', on);
        card.addEventListener('pointerleave', off);
        card.addEventListener('touchstart', () => {
          card.classList.contains('idle-on') ? off() : on();
        }, { passive: true });
      });
      // hero dock: the 54px chips come alive on hover
      document.querySelectorAll<HTMLElement>('.dock-chip').forEach((chip) => {
        const v = chip.querySelector<HTMLVideoElement>('.dock-vid');
        if (!v) return;
        chip.addEventListener('pointerenter', () => { v.play().catch(() => {}); });
        chip.addEventListener('pointerleave', () => { v.pause(); });
      });

      // Chrome pauses offscreen muted videos — nudge the standing loops
      // back to life whenever their card scrolls into view.
      if (!reduceMotion) {
        const vio = new IntersectionObserver((entries) => {
          for (const e of entries) {
            const v = (e.target as HTMLElement).querySelector<HTMLVideoElement>('.v-stand');
            if (!v) continue;
            if (e.isIntersecting) v.play().catch(() => {});
            else v.pause();
          }
        }, { threshold: 0.2 });
        document.querySelectorAll('.chapter').forEach((c) => vio.observe(c));
      }

      // ---- the story ----
      if (!reduceMotion) {
        // words fill in, scroll-linked (and reversible), like reading aloud
        const words = Array.from(document.querySelectorAll('#manifesto .w'));
        const manifesto = document.getElementById('manifesto')!;
        let ticking = false;
        function paintWords() {
          ticking = false;
          const r = manifesto.getBoundingClientRect();
          const vh = window.innerHeight;
          // progress: 0 when section enters, 1 when its bottom nears the top third
          const total = r.height - vh * 0.25;
          const gone = Math.min(Math.max(vh * 0.75 - r.top, 0), total);
          const p = total > 0 ? gone / total : 1;
          const n = Math.round(p * words.length);
          words.forEach((w, i) => w.classList.toggle('on', i < n));
        }
        window.addEventListener('scroll', () => {
          if (!ticking) { ticking = true; requestAnimationFrame(paintWords); }
        }, { passive: true, signal: ac.signal });
        paintWords();

        // chapters & proof float up
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.rv').forEach((el) => io.observe(el));

        // backdrop dresses in each coach's colors as their chapter passes
        const story = document.getElementById('story')!;
        const phases = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            story.classList.toggle('phase-manifesto', e.target.id === 'manifesto');
            if (e.target.id !== 'manifesto') story.style.removeProperty('--world');
          }
        }, { threshold: 0.25 });
        phases.observe(manifesto);
        const worlds = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            const c1 = (e.target as HTMLElement).style.getPropertyValue('--c1');
            if (c1) story.style.setProperty('--world', `color-mix(in srgb, ${c1} 7%, #0a0a0a)`);
          }
        }, { threshold: 0.6 });
        document.querySelectorAll('.chapter').forEach((c) => worlds.observe(c));
        // back to black past the chapters
        const resetW = new IntersectionObserver((es) => {
          for (const e of es) if (e.isIntersecting) story.style.removeProperty('--world');
        }, { threshold: 0.2 });
        resetW.observe(document.querySelector('.pillars')!);
      } else {
        document.querySelectorAll('#manifesto .w').forEach((w) => w.classList.add('on'));
      }
      }
      document.addEventListener('astro:page-load', initHome);
    </script>
  </body>
</html>

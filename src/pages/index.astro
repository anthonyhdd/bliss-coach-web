---
import { withBase } from '../config/apps';

// Pixel-faithful clone of the original Framer landing page (bliss-coach.com).
// Standalone layout on purpose: the Framer page has no header nav — the four
// avatar tiles link into the app sections instead.

const title = 'Bliss Coach';
const description =
  'Bliss Coach is a mobile app studio building AI-powered coaching apps that help people grow — one conversation at a time.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Bliss Coach',
  url: 'https://bliss-coach.com/',
  description,
  logo: 'https://bliss-coach.com/home/logo.png',
  sameAs: ['https://apps.apple.com/us/developer/bliss-coach/id1628409883'],
};

const avatars = [
  { src: 'amelie.webp', href: '/amelie/', alt: 'Amélie — AI French teacher', pos: '50% 18%' },
  { src: 'sofia.png', href: '/sofia/', alt: 'Sofia — AI Spanish teacher', pos: '50% 22%' },
  { src: 'alex.png', href: '/alex/', alt: 'Alex — AI interview coach', pos: '50% 14%' },
  { src: 'coach.png', href: '/charm/', alt: 'Charm — AI dating coach', pos: '50% 20%' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://bliss-coach.com/" />
    <link rel="icon" type="image/png" href={withBase('/home/logo.png')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://bliss-coach.com/" />
    <meta property="og:image" content="https://bliss-coach.com/home/logo.png" />
    <meta property="og:site_name" content="Bliss Coach" />
    <meta name="twitter:card" content="summary" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: #050505; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: #fff;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .stage {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        overflow: hidden;
      }
      /* starfield */
      .stars, .stars2 {
        position: absolute; inset: 0; pointer-events: none;
        background-image:
          radial-gradient(1.5px 1.5px at 12% 18%, rgba(255,255,255,0.7), transparent),
          radial-gradient(1px 1px at 28% 8%, rgba(255,255,255,0.5), transparent),
          radial-gradient(1.2px 1.2px at 41% 24%, rgba(255,255,255,0.6), transparent),
          radial-gradient(1px 1px at 55% 6%, rgba(255,255,255,0.45), transparent),
          radial-gradient(1.6px 1.6px at 67% 15%, rgba(255,255,255,0.7), transparent),
          radial-gradient(1px 1px at 78% 28%, rgba(255,255,255,0.5), transparent),
          radial-gradient(1.3px 1.3px at 88% 10%, rgba(255,255,255,0.6), transparent),
          radial-gradient(1px 1px at 7% 42%, rgba(255,255,255,0.4), transparent),
          radial-gradient(1.4px 1.4px at 94% 38%, rgba(255,255,255,0.55), transparent),
          radial-gradient(1px 1px at 18% 55%, rgba(255,255,255,0.4), transparent),
          radial-gradient(1.2px 1.2px at 83% 52%, rgba(255,255,255,0.5), transparent),
          radial-gradient(1px 1px at 35% 40%, rgba(255,255,255,0.35), transparent),
          radial-gradient(1px 1px at 63% 45%, rgba(255,255,255,0.35), transparent);
      }
      .stars2 {
        transform: translate(30px, 60px) scale(1.4);
        opacity: 0.5;
      }
      /* violet nebula glow behind the headline */
      .nebula {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(40% 36% at 50% 32%, rgba(104, 86, 162, 0.34), transparent 62%),
          radial-gradient(22% 18% at 50% 28%, rgba(146, 122, 212, 0.18), transparent 65%);
      }
      .content {
        position: relative;
        display: flex; flex-direction: column; align-items: center;
        padding: 0 24px;
        width: 100%;
      }
      .logo-mark {
        width: 46px; height: 46px; margin: 88px auto 48px;
        filter: brightness(1.35) drop-shadow(0 0 10px rgba(240, 205, 150, 0.35));
      }
      h1 {
        text-align: center;
        font-size: clamp(36px, 4.6vw, 64px);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1.12;
        max-width: 900px;
      }
      h1 .serif {
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: 1.04em;
        background: linear-gradient(100deg, #ffffff 45%, #f3e2f0 75%, #d9c4ee 95%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        padding-right: 0.06em;
      }
      .sub {
        margin-top: 34px;
        text-align: center;
        font-size: 19px;
        line-height: 1.55;
        color: rgba(235, 235, 245, 0.62);
        font-weight: 400;
      }
      .cta-wrap {
        margin-top: 40px;
        padding: 1px;
        border-radius: 15px;
        background: linear-gradient(115deg, #eccf9d 0%, rgba(255, 255, 255, 0.14) 35%, rgba(255, 255, 255, 0.1) 60%, #ecb9d9 100%);
        box-shadow: 0 0 30px rgba(236, 185, 217, 0.12);
        transition: box-shadow 0.2s;
      }
      .cta-wrap:hover { box-shadow: 0 0 44px rgba(236, 185, 217, 0.25); }
      .cta {
        display: block;
        background: #0b0b0b;
        border-radius: 14px;
        padding: 16px 34px;
        color: #fff;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      /* planet horizon */
      .planet {
        position: relative;
        width: 100%;
        margin-top: 56px;
        height: 300px;
        flex: 1 0 auto;
        pointer-events: none;
      }
      .planet .disc {
        position: absolute;
        left: 50%; top: 0;
        transform: translateX(-50%);
        width: 280vw; max-width: 4600px;
        height: 3400px;
        border-radius: 50%;
        background: #030303;
        box-shadow:
          0 -1px 0 rgba(255, 255, 255, 0.85),
          0 -6px 18px rgba(255, 255, 255, 0.35),
          0 -22px 60px rgba(214, 200, 255, 0.18),
          0 -70px 160px rgba(140, 120, 200, 0.12);
      }
      .planet .flare {
        position: absolute;
        left: 50%; top: -50px;
        transform: translateX(-50%);
        width: 780px; height: 120px;
        background: radial-gradient(50% 50% at 50% 50%, rgba(255, 255, 255, 0.28), transparent 70%);
        filter: blur(2px);
      }
      /* avatar row — sits on the planet surface */
      .avatars {
        position: absolute;
        left: 50%; top: 118px;
        transform: translateX(-50%);
        display: flex;
        gap: 2px;
        pointer-events: auto;
        filter: drop-shadow(0 10px 40px rgba(0, 0, 0, 0.8));
      }
      .avatars a { display: block; }
      .avatars img {
        width: 52px; height: 52px;
        object-fit: cover;
        border-radius: 12px;
        display: block;
        transition: transform 0.18s;
      }
      .avatars a:hover img { transform: translateY(-4px) scale(1.06); }
      footer {
        position: relative;
        width: 100%;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 26px 0;
        text-align: center;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.45);
        background: #050505;
      }
      @media (max-width: 640px) {
        .logo-mark { margin: 72px auto 40px; }
        .sub { font-size: 17px; }
        .planet { height: 260px; }
        .avatars { top: 100px; }
      }
    </style>
  </head>
  <body>
    <div class="stage">
      <div class="stars" aria-hidden="true"></div>
      <div class="stars2" aria-hidden="true"></div>
      <div class="nebula" aria-hidden="true"></div>

      <div class="content">
        <img class="logo-mark" src={withBase('/home/logo.png')} alt="Bliss Coach logo" width="46" height="46" />
        <h1>
          Building the world's largest<br />
          portfolio of <span class="serif">AI coaching apps</span>
        </h1>
        <p class="sub">Specialized AI coaches<br />for every area of life.</p>
        <div class="cta-wrap">
          <a class="cta" href="https://apps.apple.com/us/developer/bliss-coach/id1628409883">Get Started</a>
        </div>
      </div>

      <div class="planet">
        <div class="disc" aria-hidden="true"></div>
        <div class="flare" aria-hidden="true"></div>
        <nav class="avatars" aria-label="Our apps">
          {avatars.map((a) => (
            <a href={withBase(a.href)} title={a.alt}>
              <img src={withBase(`/home/${a.src}`)} alt={a.alt} style={`object-position:${a.pos}`} width="52" height="52" loading="eager" />
            </a>
          ))}
        </nav>
      </div>

      <footer>© Bliss Coach</footer>
    </div>
  </body>
</html>

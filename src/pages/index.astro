---
import fs from 'node:fs';
import { ClientRouter } from 'astro:transitions';
import { withBase, avatarFor } from '../config/apps';
import Analytics from '../components/Analytics.astro';

// Coach videos are opt-in: drop public/home/video/{slug}.mp4 and the chapter
// card upgrades from portrait to a muted looping video at the next build.
const hasVideo = (slug: string) => fs.existsSync(`public/home/video/${slug}.mp4`);
const hasIdle = (slug: string) => fs.existsSync(`public/home/video/${slug}-idle.mp4`);

// Pixel-faithful clone of the original Framer landing page (bliss-coach.com).
// All values below were measured on the live Framer page (computed styles):
// h1 60/66 w500 ls-3px, text-clip gradient #FBDBFF→#FFF at 15%; sub 18/27 white/70;
// button inner 48px r10.5 pad 16x32 fs13 w600 on #0a0a0a, 1.5px conic border
// (gold #FFDC83 → salmon #FFABAD → pink #FFC1F7) + blurred conic glow behind;
// horizon = 2242x955 ellipse, bg #0a0a0a, inset 0 2px 20px #fff rim +
// 0 -10px 50px rgba(255,255,255,.49) halo + 787x111 radial flare blur(57px);
// avatars 54x66 r16 overlapping -5px, 90px under the horizon apex;
// hero card has a warm inset vignette rgba(217,119,87) + side/top fades.
// The starfield + violet nebula are canvas-driven on Framer → replicated with a
// tiny canvas script (stars) + CSS radial (nebula).

const title = 'Bliss Coach';
const description =
  'Bliss Coach is a mobile app studio building AI-powered coaching apps that help people grow — one conversation at a time.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Bliss Coach',
  url: 'https://bliss-coach.com/',
  description,
  logo: 'https://bliss-coach.com/home/logo.png',
  sameAs: ['https://apps.apple.com/us/developer/bliss-coach/id1628409883'],
};

const avatars = [
  { slug: 'amelie', src: 'amelie.webp', href: '/amelie/', alt: 'Amélie — AI French teacher', pos: '50% 12%' },
  { slug: 'sofia', src: 'sofia.png', href: '/sofia/', alt: 'Sofia — AI Spanish teacher', pos: '50% 16%' },
  { slug: 'alex', src: 'alex.png', href: '/alex/', alt: 'Alex — AI interview coach', pos: '50% 10%' },
  { slug: 'charm', src: 'coach.png', href: '/charm/', alt: 'Charm — AI dating coach', pos: '50% 14%' },
  { slug: 'mila', src: 'mila.jpg', href: '/mila/', alt: 'Mila — AI dietician', pos: '50% 50%' },
  { slug: 'astra', src: 'astra.jpg', href: '/astra/', alt: 'Astra — AI astrologer', pos: '50% 50%' },
];

// Real store reviews (from the apps' App Store pages).
const REVIEWS = [
  { name: 'Jane', color: '#FF6B35', text: 'I improved my pronunciation in just a few days.' },
  { name: 'Marcus', color: '#C9A14A', text: 'Charm helped me say the right thing. We’re exclusive now.' },
  { name: 'Emily', color: '#FF4D9E', text: 'Sofia finally made me comfortable speaking Spanish.' },
  { name: 'Tom', color: '#8a6a1f', text: 'Updated my bio with Charm, tripled my matches in a week.' },
  { name: 'Jake', color: '#C084FC', text: 'I used to stare at my screen for 20 min. Now I just open and get replies.' },
  { name: 'Rayan', color: '#22C55E', text: 'Tried Charm, got 3 dates in two weeks. Lesson learned.' },
];

// Scroll-story manifesto — revealed word by word as you scroll.
const manifesto = [
  'A great coach changes everything.',
  'Most people never get one — coaching was a luxury. $200 an hour, if you knew the right people.',
  'So we built one for everyone. Start messy, keep going, surprise yourself.',
  'Get better, every day.',
];

// Six chapters — one per coach, with a real line from each app.
const coaches = [
  {
    slug: 'sofia', name: 'Sofia', craft: 'teaches Spanish', img: 'sofia.png', pos: '50% 16%',
    line: '¿Vamos al cine después?', reply: '¡Buena idea, vamos!',
    blurb: 'Real conversations, instant corrections, zero drills. Fluent 10 minutes a day.',
    c1: '#FF2D2D', c2: '#FF4D9E',
  },
  {
    slug: 'amelie', name: 'Amélie', craft: 'teaches French', img: 'amelie.webp', pos: '50% 12%',
    line: 'Ça vous dit un ciné ce soir ?', reply: 'Oui, on va voir quoi ?',
    blurb: 'Real Parisian French, corrected as you go. Finally fit in anywhere.',
    c1: '#6D28D9', c2: '#DB2777',
  },
  {
    slug: 'alex', name: 'Alex', craft: 'lands your next job', img: 'alex.png', pos: '50% 10%',
    line: "Let's talk about your experience.", reply: null,
    blurb: 'Mock interviews built around the real job posting. Walk in prepared.',
    c1: '#60A5FA', c2: '#C084FC',
  },
  {
    slug: 'charm', name: 'Charm', craft: 'fixes your texting game', img: 'coach.png', pos: '50% 14%',
    line: 'Be more gentle and calm. Don’t stress her out…', reply: null,
    blurb: 'Paste the convo. Charm reads the subtext and writes the reply.',
    c1: '#C9A14A', c2: '#8a6a1f',
  },
  {
    slug: 'mila', name: 'Mila', craft: 'plans your plate', img: 'mila.jpg', pos: '50% 50%',
    line: 'One pizza 🍕 isn’t a setback. It’s Tuesday.', reply: null,
    blurb: 'Snap your meal, get answers. No counting, no guilt — just progress.',
    c1: '#16A34A', c2: '#14B8A6',
  },
  {
    slug: 'astra', name: 'Astra', craft: 'reads your sky', img: 'astra.jpg', pos: '50% 50%',
    line: 'Sun in Leo, moon in Pisces — no wonder today felt big.', reply: null,
    blurb: 'Your natal chart, decoded in plain language. Daily guidance from your own sky.',
    c1: '#6366F1', c2: '#C9A14A',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <ClientRouter />
    <Analytics />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://bliss-coach.com/" />
    <link rel="icon" type="image/png" href={withBase('/home/logo.png')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://bliss-coach.com/" />
    <meta property="og:image" content="https://bliss-coach.com/home/og.png" />
    <meta property="og:site_name" content="Bliss Coach" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      html, body { background: #0a0a0a; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: #fff;
        -webkit-font-smoothing: antialiased;
        /* `clip`, not `hidden`: `hidden` turns body into a scroll container, which
           silently breaks `position: sticky` on descendants (the coach chapters
           stack on scroll). `clip` kills horizontal overflow without a scrollport.
           Same trick already used on .story. */
        overflow-x: clip;
      }
      .banner {
        display: block;
        background: #101014;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        text-decoration: none;
        text-align: center;
        padding: 9px 16px;
      }
      .banner-inner {
        font-family: ui-monospace, 'SF Mono', Menlo, monospace;
        font-size: 12.5px;
        color: rgba(255, 255, 255, 0.8);
        letter-spacing: 0.02em;
      }
      .banner-inner i { color: #7ee787; font-style: normal; margin-right: 6px; }
      .banner-inner mark { background: #ffdc83; color: #0a0a0a; padding: 1px 6px; border-radius: 4px; font-weight: 700; }
      .banner-inner b { color: #ffdc83; }
      .banner:hover .banner-inner { color: #fff; }
      @media (max-width: 640px) { .banner-inner { font-size: 11px; } }
      .card {
        position: relative;
        width: 100%;
        margin: 0 auto;
        height: max(800px, calc(100vh - 53px));
        overflow: hidden;
        box-shadow:
          rgba(217, 119, 87, 0.7) 0px 0px 15px 0px inset,
          rgba(217, 119, 87, 0.5) 0px 0px 25px 0px inset,
          rgba(217, 119, 87, 0.2) 0px 0px 35px 0px inset;
      }
      /* canvas starfield (replaces Framer's canvas) */
      #stars { position: absolute; inset: 0; width: 100%; height: 100%; }
      /* violet nebula */
      .nebula {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(44% 40% at 50% 36%, rgba(118, 98, 188, 0.34), rgba(94, 74, 152, 0.14) 58%, transparent 78%),
          radial-gradient(24% 20% at 50% 30%, rgba(158, 132, 224, 0.20), transparent 68%);
      }
      /* edge fades measured on the original: 600px side fades + 100px top fade */
      .fade-l, .fade-r, .fade-t {
        position: absolute; pointer-events: none; top: 0; bottom: 0;
      }
      .fade-l { left: 0; width: 45%; background: linear-gradient(90deg, #0a0a0a 0%, rgba(10,10,10,0) 100%); }
      .fade-r { right: 0; width: 45%; background: linear-gradient(270deg, #0a0a0a 0%, rgba(10,10,10,0) 100%); }
      .fade-t { left: 0; right: 0; height: 100px; bottom: auto; background: linear-gradient(#0a0a0a 0%, rgba(10,10,10,0) 100%); }

      .content {
        position: relative;
        display: flex; flex-direction: column; align-items: center;
        padding: 0 24px;
        will-change: transform, opacity;
      }
      /* mobilefirst-style entrance: hero sharpens out of a blur */
      @media (prefers-reduced-motion: no-preference) {
        .logo-mark, h1, .sub, .cta-wrap {
          animation: hero-in 1.1s cubic-bezier(0.2, 0.7, 0.2, 1) both;
        }
        .sub { animation-delay: 0.12s; }
        .cta-wrap { animation-delay: 0.24s; }
        @keyframes hero-in {
          from { opacity: 0; filter: blur(14px); transform: translateY(14px); }
          to   { opacity: 1; filter: blur(0);    transform: none; }
        }
      }
      /* parallax layers driven by the pointer */
      #stars, .nebula { will-change: transform; }
      .logo-mark {
        width: 52px; height: 52px; margin: 69px auto 26px;
        filter: brightness(1.25) drop-shadow(0 0 14px rgba(200, 170, 255, 0.28));
      }
      h1 {
        text-align: center;
        font-weight: 500;
        font-size: clamp(38px, 4.7vw, 60px);
        line-height: 1.1;
        letter-spacing: -0.05em;
        background: linear-gradient(0deg, #fbdbff 0%, #ffffff 15%, #ffffff 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      h1 .serif {
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: -0.01em;
        padding-right: 0.05em;
        /* keep "AI coaching apps" together on one line at every width */
        white-space: nowrap;
      }
      /* Two explicit headline variants, toggled by viewport, so the line
         count is fully deterministic and can never auto-wrap into extra
         lines. nowrap forces the hard-coded <br> layout at any width.
         Desktop: "Building the world's largest" / "portfolio of" / "AI coaching apps"
         Mobile:  "Building the world's" / "largest portfolio of" / "AI coaching apps" */
      h1 .t-mobile { display: none; }
      h1 .t-desktop { display: inline; }
      .sub {
        margin-top: 27px;
        text-align: center;
        font-size: 18px;
        line-height: 27px;
        color: rgba(255, 255, 255, 0.7);
        font-weight: 400;
      }
      /* highlighter marks — mobilefirst marker strokes */
      .hl {
        background: linear-gradient(92deg, #ffdc83, #ffabad, #ffc1f7);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        font-weight: 600;
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
      }
      .manifesto .w.hlw {
        background: linear-gradient(104deg, transparent 3%, rgba(255, 220, 131, 0.34) 10%, rgba(255, 220, 131, 0.38) 90%, transparent 97%);
        border-radius: 3px;
        padding: 0 3px;
      }

      /* CTA — 1.5px conic border + blurred conic glow behind */
      .cta-wrap {
        position: relative;
        margin-top: 56px;
        padding: 1.5px;
        border-radius: 12px;
      }
      .cta-beam {
        position: absolute;
        inset: 0;
        border-radius: 12px;
        overflow: hidden;
      }
      .cta-beam::before {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        width: 420px; height: 420px;
        margin: -210px 0 0 -210px;
        background: conic-gradient(from 80.568deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 70%, #ffdc83 78%, #ffabad 86%, #ffc1f7 94%, rgba(0,0,0,0) 100%);
        animation: beam-spin 2.5s linear infinite;
      }
      @keyframes beam-spin { to { transform: rotate(360deg); } }
      @media (prefers-reduced-motion: reduce) { .cta-beam::before { animation: none; } }
      .cta-wrap::before {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        transform: translate(-50%, -50%);
        width: 220px; height: 120px;
        background: conic-gradient(from 80.568deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 70%, #ffdc83 78%, #ffabad 86%, #ffc1f7 94%, rgba(0,0,0,0) 100%);
        filter: blur(30px);
        opacity: 0.32;
        pointer-events: none;
        z-index: -1;
      }
      .cta {
        position: relative;
        display: block;
        background: #0a0a0a;
        border-radius: 10.5px;
        padding: 16px 32px;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        line-height: 1.2;
        text-decoration: none;
      }
      /* planet horizon — 74px under the button */
      .horizon {
        position: relative;
        width: 100%;
        flex: 1 0 auto;
        margin-top: 74px;
        min-height: 240px;
        pointer-events: none;
      }
      .horizon .disc {
        position: absolute;
        left: 50%; top: 0;
        transform: translateX(-50%);
        width: 187%;
        min-width: 1500px;
        height: 955px;
        border-radius: 100%;
        background: #0a0a0a;
        box-shadow:
          rgb(255, 255, 255) 0px 2px 20px 0px inset,
          rgba(255, 255, 255, 0.49) 0px -10px 50px 1px;
      }
      .horizon .flare {
        position: absolute;
        left: 50%; top: 0;
        transform: translate(-50%, -50%);
        width: 787px; height: 111px;
        background: radial-gradient(50% 50%, rgba(255, 255, 255, 0.5) 0%, rgba(10, 10, 10, 0) 100%);
        filter: blur(57px);
      }
      /* avatars — 54x66 r16, overlapping 5px, 90px under the apex */
      .avatars {
        position: absolute;
        left: 50%; top: 90px;
        transform: translateX(-50%);
        display: flex;
        pointer-events: auto;
      }
      .avatars a { display: block; margin-right: -5px; }
      .avatars a:last-child { margin-right: 0; }
      .avatars img {
        width: 54px; height: 66px;
        object-fit: cover;
        border-radius: 16px;
        display: block;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.7);
        transition: transform 0.18s;
      }
      .avatars a:hover img { transform: translateY(-4px); }
      .dock-chip { position: relative; }
      .dock-vid {
        position: absolute; inset: 0; width: 54px; height: 66px;
        object-fit: cover; border-radius: 16px; display: block;
        opacity: 0; transition: opacity 0.3s ease, transform 0.18s;
        pointer-events: none;
      }
      .dock-chip:hover .dock-vid { opacity: 1; transform: translateY(-4px); }
      /* --- footer: the last thing you see should still be fun --- */
      .foot {
        position: relative;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 64px 24px 34px;
        text-align: center;
        overflow: hidden;
      }
      /* KAMO easter egg — the hidden 3D figure peeking up in the footer; rises on hover, links to the app */
      .foot-kamo {
        position: absolute;
        left: clamp(18px, 8vw, 96px);
        bottom: -96px;
        display: block;
        width: 74px;
        opacity: 0.82;
        z-index: 0;
        filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.45));
        transition: transform 0.55s cubic-bezier(0.2, 0.9, 0.3, 1), opacity 0.4s ease;
      }
      .foot-kamo img { display: block; width: 100%; height: auto; }
      /* KAMO tagline — sits above the head, fades in with the peek */
      .foot-kamo-tag {
        position: absolute;
        bottom: calc(100% + 16px);
        left: 0;                        /* character hugs the left edge — never overflows */
        font-size: 11px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase;
        padding: 7px 12px; border-radius: 999px;
        background: #ffdc83; color: #17130a;
        box-shadow: 0 10px 26px rgba(0, 0, 0, 0.55);
        white-space: nowrap;
        rotate: -4deg;
        opacity: 0; transform: translateY(6px);
        transition: opacity 0.4s ease, transform 0.55s cubic-bezier(0.2, 0.9, 0.3, 1);
      }
      .foot:hover .foot-kamo-tag { opacity: 1; transform: translateY(0); }
      .foot:hover .foot-kamo { transform: translateY(-48px); opacity: 1; }
      .foot-board, .foot-mark, .foot-tag, .foot-links, .foot-stickers { position: relative; z-index: 1; }
      @media (max-width: 640px) {
        .foot-kamo { width: 56px; bottom: -74px; left: 14px; }
        /* collides with the wordmark at this width, and hover reveals don't fire on touch anyway */
        .foot-kamo-tag { display: none; }
      }
      @media (prefers-reduced-motion: reduce) { .foot-kamo, .foot-kamo-tag { transition: none; } }
      .foot-grid {
        position: absolute; inset: 0; pointer-events: none;
        background-image:
          linear-gradient(rgba(255, 220, 131, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 220, 131, 0.05) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: radial-gradient(70% 90% at 50% 100%, #000, transparent 80%);
        -webkit-mask-image: radial-gradient(70% 90% at 50% 100%, #000, transparent 80%);
      }
      .foot-stickers { position: relative; height: 0; }
      .stk {
        position: absolute;
        font-size: 11px; font-weight: 800; letter-spacing: 0.14em;
        padding: 8px 14px; border-radius: 999px;
        background: #f7f4ec; color: #17130a;
        box-shadow: 0 10px 26px rgba(0, 0, 0, 0.55);
        white-space: nowrap;
      }
      .stk-1 { left: calc(50% - 420px); top: 8px; rotate: -8deg; background: #ffdc83; }
      .stk-2 { right: calc(50% - 470px); top: 2px; rotate: 5deg; }
      .stk-3 { right: calc(50% - 400px); top: 74px; rotate: -4deg; background: #ffc1f7; }
      @media (max-width: 900px) {
        .stk { position: static; display: inline-block; margin: 0 6px 10px; rotate: none; }
        .stk-1 { rotate: -3deg; } .stk-2 { rotate: 2deg; } .stk-3 { rotate: -2deg; }
        .foot-stickers { height: auto; margin-bottom: 18px; }
      }
      .foot-board { position: relative; display: flex; gap: 10px; justify-content: center; margin-bottom: 26px; }
      .foot-board img {
        width: 54px; height: 54px; border-radius: 13px; display: block;
        box-shadow: 0 8px 22px rgba(0, 0, 0, 0.5);
        transition: transform 0.18s;
      }
      .foot-board a:hover img { transform: translateY(-5px) scale(1.06); }
      .foot-mark { position: relative; font-size: 26px; font-weight: 700; letter-spacing: -0.02em; }
      .foot-mark em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400; }
      .foot-tag {
        position: relative;
        font-family: 'Instrument Serif', Georgia, serif; font-style: italic;
        color: rgba(255, 255, 255, 0.68); font-size: clamp(20px, 3vw, 27px);
        margin: 10px 0 28px;
      }
      .foot-links { position: relative; display: flex; gap: 22px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: rgba(255, 255, 255, 0.45); }
      .foot-links a { color: rgba(255, 255, 255, 0.55); text-decoration: none; }
      .foot-links a:hover { color: #fff; }
      @media (max-width: 640px) {
        .content { padding: 0 20px; }
        .logo-mark { margin-top: 56px; }
        /* scale the headline with the viewport so it always fits the screen
           instead of being clipped at the 38px floor */
        h1 { font-size: clamp(24px, 7.6vw, 40px); }
        h1 .t-desktop { display: none; }
        h1 .t-mobile { display: inline; white-space: nowrap; }
        .sub { font-size: 16px; line-height: 24px; max-width: 34ch; }
        .sub br { display: none; }
        .cta-wrap { margin-top: 44px; }
        .horizon { margin-top: 60px; }
      }

      /* ============ the story below the hero ============ */

      /* backdrop hue shifts as chapters scroll by */
      .story {
        position: relative;
        background: var(--world, #0a0a0a);
        transition: background 1.2s ease;
        overflow-x: clip;
      }
      .story.phase-manifesto { --world: #120d1e; }

      /* --- manifesto: words fill in as you scroll --- */
      .manifesto {
        max-width: 880px;
        margin: 0 auto;
        padding: 20vh 24px 18vh;
        text-align: center;
      }
      .manifesto p {
        font-size: clamp(24px, 3.4vw, 42px);
        line-height: 1.35;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-bottom: clamp(28px, 4vw, 48px);
      }
      .manifesto p:last-child {
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0;
        font-size: clamp(28px, 4vw, 50px);
        /* ONE gradient across the whole line — painted on the paragraph,
           clipped by all its words at once; words reveal it by turning
           transparent, so the ramp never restarts per word */
        background: linear-gradient(92deg, #ffdc83 0%, #ffabad 50%, #ffc1f7 100%);
        -webkit-background-clip: text;
        background-clip: text;
      }
      .manifesto p:last-child .w.on { color: transparent; }
      .manifesto .w {
        color: rgba(255, 255, 255, 0.16);
        transition: color 0.35s ease;
      }
      .manifesto .w.on { color: #fff; }
      @media (prefers-reduced-motion: reduce) {
        .manifesto .w { color: #fff; }
        .manifesto p:last-child .w { color: transparent; }
      }

      /* floating props — the tangible world of the manifesto */
      .manifesto { position: relative; }
      .manifesto .props { position: absolute; inset: 0; pointer-events: none; }
      .prop {
        position: absolute;
        border-radius: 10px;

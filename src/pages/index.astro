---
import fs from 'node:fs';
import { withBase } from '../config/apps';
import Analytics from '../components/Analytics.astro';

// Coach videos are opt-in: drop public/home/video/{slug}.mp4 and the chapter
// card upgrades from portrait to a muted looping video at the next build.
const hasVideo = (slug: string) => fs.existsSync(`public/home/video/${slug}.mp4`);

// Pixel-faithful clone of the original Framer landing page (bliss-coach.com).
// All values below were measured on the live Framer page (computed styles):
// h1 60/66 w500 ls-3px, text-clip gradient #FBDBFF→#FFF at 15%; sub 18/27 white/70;
// button inner 48px r10.5 pad 16x32 fs13 w600 on #0a0a0a, 1.5px conic border
// (gold #FFDC83 → salmon #FFABAD → pink #FFC1F7) + blurred conic glow behind;
// horizon = 2242x955 ellipse, bg #0a0a0a, inset 0 2px 20px #fff rim +
// 0 -10px 50px rgba(255,255,255,.49) halo + 787x111 radial flare blur(57px);
// avatars 54x66 r16 overlapping -5px, 90px under the horizon apex;
// hero card has a warm inset vignette rgba(217,119,87) + side/top fades.
// The starfield + violet nebula are canvas-driven on Framer → replicated with a
// tiny canvas script (stars) + CSS radial (nebula).

const title = 'Bliss Coach';
const description =
  'Bliss Coach is a mobile app studio building AI-powered coaching apps that help people grow — one conversation at a time.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Bliss Coach',
  url: 'https://bliss-coach.com/',
  description,
  logo: 'https://bliss-coach.com/home/logo.png',
  sameAs: ['https://apps.apple.com/us/developer/bliss-coach/id1628409883'],
};

const avatars = [
  { src: 'amelie.webp', href: '/amelie/', alt: 'Amélie — AI French teacher', pos: '50% 12%' },
  { src: 'sofia.png', href: '/sofia/', alt: 'Sofia — AI Spanish teacher', pos: '50% 16%' },
  { src: 'alex.png', href: '/alex/', alt: 'Alex — AI interview coach', pos: '50% 10%' },
  { src: 'coach.png', href: '/charm/', alt: 'Charm — AI dating coach', pos: '50% 14%' },
  { src: 'mila.jpg', href: '/mila/', alt: 'Mila — AI dietician', pos: '50% 50%' },
  { src: 'astra.jpg', href: '/astra/', alt: 'Astra — AI astrologer', pos: '50% 50%' },
];

// Scroll-story manifesto — revealed word by word as you scroll.
const manifesto = [
  'A great coach changes everything.',
  'Most people never get one — coaching was a luxury. $200 an hour, if you knew the right people.',
  'So we build coaches that live in your pocket. They talk with you, listen to you, and remember you.',
  'One coach, one craft, done right.',
];

// Six chapters — one per coach, with a real line from each app.
const coaches = [
  {
    slug: 'sofia', name: 'Sofia', craft: 'teaches Spanish', img: 'sofia.png', pos: '50% 16%',
    line: '¿Vamos al cine después?', reply: '¡Buena idea, vamos!',
    blurb: 'Real conversations, instant corrections, zero drills. Fluent 10 minutes a day.',
    c1: '#FF2D2D', c2: '#FF4D9E',
  },
  {
    slug: 'amelie', name: 'Amélie', craft: 'teaches French', img: 'amelie.webp', pos: '50% 12%',
    line: 'Ça vous dit un ciné ce soir ?', reply: 'Oui, on va voir quoi ?',
    blurb: 'Real Parisian French, corrected as you go. Finally fit in anywhere.',
    c1: '#6D28D9', c2: '#DB2777',
  },
  {
    slug: 'alex', name: 'Alex', craft: 'lands your next job', img: 'alex.png', pos: '50% 10%',
    line: "Let's talk about your experience.", reply: null,
    blurb: 'Mock interviews built around the real job posting. Walk in prepared.',
    c1: '#60A5FA', c2: '#C084FC',
  },
  {
    slug: 'charm', name: 'Charm', craft: 'fixes your texting game', img: 'coach.png', pos: '50% 14%',
    line: 'Be more gentle and calm. Don’t stress her out…', reply: null,
    blurb: 'Paste the convo. Charm reads the subtext and writes the reply.',
    c1: '#C9A14A', c2: '#8a6a1f',
  },
  {
    slug: 'mila', name: 'Mila', craft: 'plans your plate', img: 'mila.jpg', pos: '50% 50%',
    line: 'One pizza 🍕 isn’t a setback. It’s Tuesday.', reply: null,
    blurb: 'Snap your meal, get answers. No counting, no guilt — just progress.',
    c1: '#16A34A', c2: '#14B8A6',
  },
  {
    slug: 'astra', name: 'Astra', craft: 'reads your sky', img: 'astra.jpg', pos: '50% 50%',
    line: 'Sun in Leo, moon in Pisces — no wonder today felt big.', reply: null,
    blurb: 'Your natal chart, decoded in plain language. Daily guidance from your own sky.',
    c1: '#6366F1', c2: '#C9A14A',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <Analytics />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://bliss-coach.com/" />
    <link rel="icon" type="image/png" href={withBase('/home/logo.png')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://bliss-coach.com/" />
    <meta property="og:image" content="https://bliss-coach.com/home/logo.png" />
    <meta property="og:site_name" content="Bliss Coach" />
    <meta name="twitter:card" content="summary" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap"
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: #0a0a0a; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        color: #fff;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .card {
        position: relative;
        width: 100%;
        margin: 0 auto;
        height: max(800px, calc(100vh - 53px));
        overflow: hidden;
        box-shadow:
          rgba(217, 119, 87, 0.7) 0px 0px 15px 0px inset,
          rgba(217, 119, 87, 0.5) 0px 0px 25px 0px inset,
          rgba(217, 119, 87, 0.2) 0px 0px 35px 0px inset;
      }
      /* canvas starfield (replaces Framer's canvas) */
      #stars { position: absolute; inset: 0; width: 100%; height: 100%; }
      /* violet nebula */
      .nebula {
        position: absolute; inset: 0; pointer-events: none;
        background:
          radial-gradient(44% 40% at 50% 36%, rgba(118, 98, 188, 0.34), rgba(94, 74, 152, 0.14) 58%, transparent 78%),
          radial-gradient(24% 20% at 50% 30%, rgba(158, 132, 224, 0.20), transparent 68%);
      }
      /* edge fades measured on the original: 600px side fades + 100px top fade */
      .fade-l, .fade-r, .fade-t {
        position: absolute; pointer-events: none; top: 0; bottom: 0;
      }
      .fade-l { left: 0; width: 45%; background: linear-gradient(90deg, #0a0a0a 0%, rgba(10,10,10,0) 100%); }
      .fade-r { right: 0; width: 45%; background: linear-gradient(270deg, #0a0a0a 0%, rgba(10,10,10,0) 100%); }
      .fade-t { left: 0; right: 0; height: 100px; bottom: auto; background: linear-gradient(#0a0a0a 0%, rgba(10,10,10,0) 100%); }

      .content {
        position: relative;
        display: flex; flex-direction: column; align-items: center;
        padding: 0 24px;
      }
      .logo-mark {
        width: 52px; height: 52px; margin: 69px auto 26px;
        filter: brightness(1.25) drop-shadow(0 0 14px rgba(200, 170, 255, 0.28));
      }
      h1 {
        text-align: center;
        font-weight: 500;
        font-size: clamp(38px, 4.7vw, 60px);
        line-height: 1.1;
        letter-spacing: -0.05em;
        background: linear-gradient(0deg, #fbdbff 0%, #ffffff 15%, #ffffff 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      h1 .serif {
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: -0.01em;
        padding-right: 0.05em;
        /* keep "AI coaching apps" together on one line at every width */
        white-space: nowrap;
      }
      /* Two explicit headline variants, toggled by viewport, so the line
         count is fully deterministic and can never auto-wrap into extra
         lines. nowrap forces the hard-coded <br> layout at any width.
         Desktop: "Building the world's largest" / "portfolio of" / "AI coaching apps"
         Mobile:  "Building the world's" / "largest portfolio of" / "AI coaching apps" */
      h1 .t-mobile { display: none; }
      h1 .t-desktop { display: inline; }
      .sub {
        margin-top: 27px;
        text-align: center;
        font-size: 18px;
        line-height: 27px;
        color: rgba(255, 255, 255, 0.7);
        font-weight: 400;
      }
      /* CTA — 1.5px conic border + blurred conic glow behind */
      .cta-wrap {
        position: relative;
        margin-top: 56px;
        padding: 1.5px;
        border-radius: 12px;
      }
      .cta-beam {
        position: absolute;
        inset: 0;
        border-radius: 12px;
        overflow: hidden;
      }
      .cta-beam::before {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        width: 420px; height: 420px;
        margin: -210px 0 0 -210px;
        background: conic-gradient(from 80.568deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 70%, #ffdc83 78%, #ffabad 86%, #ffc1f7 94%, rgba(0,0,0,0) 100%);
        animation: beam-spin 2.5s linear infinite;
      }
      @keyframes beam-spin { to { transform: rotate(360deg); } }
      @media (prefers-reduced-motion: reduce) { .cta-beam::before { animation: none; } }
      .cta-wrap::before {
        content: '';
        position: absolute;
        left: 50%; top: 50%;
        transform: translate(-50%, -50%);
        width: 220px; height: 120px;
        background: conic-gradient(from 80.568deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 70%, #ffdc83 78%, #ffabad 86%, #ffc1f7 94%, rgba(0,0,0,0) 100%);
        filter: blur(30px);
        opacity: 0.32;
        pointer-events: none;
        z-index: -1;
      }
      .cta {
        position: relative;
        display: block;
        background: #0a0a0a;
        border-radius: 10.5px;
        padding: 16px 32px;
        color: #fff;
        font-size: 13px;
        font-weight: 600;
        line-height: 1.2;
        text-decoration: none;
      }
      /* planet horizon — 74px under the button */
      .horizon {
        position: relative;
        width: 100%;
        flex: 1 0 auto;
        margin-top: 74px;
        min-height: 240px;
        pointer-events: none;
      }
      .horizon .disc {
        position: absolute;
        left: 50%; top: 0;
        transform: translateX(-50%);
        width: 187%;
        min-width: 1500px;
        height: 955px;
        border-radius: 100%;
        background: #0a0a0a;
        box-shadow:
          rgb(255, 255, 255) 0px 2px 20px 0px inset,
          rgba(255, 255, 255, 0.49) 0px -10px 50px 1px;
      }
      .horizon .flare {
        position: absolute;
        left: 50%; top: 0;
        transform: translate(-50%, -50%);
        width: 787px; height: 111px;
        background: radial-gradient(50% 50%, rgba(255, 255, 255, 0.5) 0%, rgba(10, 10, 10, 0) 100%);
        filter: blur(57px);
      }
      /* avatars — 54x66 r16, overlapping 5px, 90px under the apex */
      .avatars {
        position: absolute;
        left: 50%; top: 90px;
        transform: translateX(-50%);
        display: flex;
        pointer-events: auto;
      }
      .avatars a { display: block; margin-right: -5px; }
      .avatars a:last-child { margin-right: 0; }
      .avatars img {
        width: 54px; height: 66px;
        object-fit: cover;
        border-radius: 16px;
        display: block;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.7);
        transition: transform 0.18s;
      }
      .avatars a:hover img { transform: translateY(-4px); }
      .foot-apps { display: flex; gap: 22px; justify-content: center; margin-bottom: 14px; flex-wrap: wrap; }
      .foot-apps a { color: rgba(255, 255, 255, 0.55); font-size: 13px; text-decoration: none; transition: color 0.15s; }
      .foot-apps a:hover { color: #fff; }
      footer {
        position: relative;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 17px 0;
        text-align: center;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.45);
      }
      @media (max-width: 640px) {
        .content { padding: 0 20px; }
        .logo-mark { margin-top: 56px; }
        /* scale the headline with the viewport so it always fits the screen
           instead of being clipped at the 38px floor */
        h1 { font-size: clamp(24px, 7.6vw, 40px); }
        h1 .t-desktop { display: none; }
        h1 .t-mobile { display: inline; white-space: nowrap; }
        .sub { font-size: 16px; line-height: 24px; }
        .cta-wrap { margin-top: 44px; }
        .horizon { margin-top: 60px; }
      }

      /* ============ the story below the hero ============ */

      /* backdrop hue shifts as chapters scroll by */
      .story {
        position: relative;
        background: #0a0a0a;
        transition: background 1.2s ease;
      }
      .story.phase-manifesto { background: #120d1e; }
      .story.phase-coaches { background: #0a0a0a; }

      /* --- manifesto: words fill in as you scroll --- */
      .manifesto {
        max-width: 880px;
        margin: 0 auto;
        padding: 20vh 24px 18vh;
        text-align: center;
      }
      .manifesto p {
        font-size: clamp(24px, 3.4vw, 42px);
        line-height: 1.35;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-bottom: clamp(28px, 4vw, 48px);
      }
      .manifesto p:last-child {
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0;
        font-size: clamp(28px, 4vw, 50px);
      }
      .manifesto .w {
        color: rgba(255, 255, 255, 0.16);
        transition: color 0.35s ease;
      }
      .manifesto .w.on { color: #fff; }
      @media (prefers-reduced-motion: reduce) {
        .manifesto .w { color: #fff; }
      }

      /* --- coach chapters --- */
      .coaches {
        max-width: 1080px;
        margin: 0 auto;
        padding: 4vh 24px 10vh;
        display: flex;
        flex-direction: column;
        gap: clamp(20px, 3vw, 32px);
      }
      .coaches-kicker {
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
        margin-bottom: clamp(24px, 4vw, 44px);
      }
      .chapter {
        --c1: #fff; --c2: #fff;
        position: relative;
        display: flex;
        align-items: center;
        gap: clamp(20px, 4vw, 44px);
        padding: clamp(22px, 3.4vw, 40px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background:
          radial-gradient(120% 160% at 12% 0%, color-mix(in srgb, var(--c1) 16%, transparent), transparent 55%),
          radial-gradient(120% 160% at 95% 110%, color-mix(in srgb, var(--c2) 12%, transparent), transparent 55%),
          #101014;
        overflow: hidden;
        text-decoration: none;
        color: #fff;
        transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
      }
      .chapter:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--c2) 45%, rgba(255,255,255,0.08));
        box-shadow: 0 24px 70px color-mix(in srgb, var(--c1) 22%, transparent);
      }
      .chapter .portrait {
        flex: 0 0 auto;
        width: clamp(96px, 14vw, 148px);
        height: clamp(118px, 17vw, 180px);
        border-radius: 22px;
        object-fit: cover;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.65);
      }
      .chapter .txt { min-width: 0; }
      .chapter .bubble {
        display: inline-block;
        max-width: 100%;
        background: rgba(255, 255, 255, 0.09);
        border: 1px solid rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(6px);
        border-radius: 16px 16px 16px 4px;
        padding: 10px 16px;
        font-size: clamp(14px, 1.7vw, 16.5px);
        font-weight: 600;
        color: #fff;
        margin-bottom: 8px;
      }
      .chapter .bubble-reply {
        display: inline-block;
        border-radius: 16px 16px 4px 16px;
        padding: 8px 14px;
        font-size: clamp(13px, 1.5vw, 14.5px);
        font-weight: 600;
        color: #0a0a0a;
        background: linear-gradient(92deg, color-mix(in srgb, var(--c1) 80%, #fff), color-mix(in srgb, var(--c2) 80%, #fff));
        margin: 0 0 14px 22px;
      }
      .chapter h3 {
        font-size: clamp(20px, 2.6vw, 28px);
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 6px 0 6px;
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      }
      .chapter h3 .app-ic {
        width: 30px; height: 30px; border-radius: 8px; display: inline-block;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.5);
      }
      .chapter h3 .craft {
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-weight: 400;
        background: linear-gradient(92deg, color-mix(in srgb, var(--c1) 85%, #fff), color-mix(in srgb, var(--c2) 85%, #fff));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        padding-right: 0.08em;
      }
      .chapter .blurb {
        color: rgba(255, 255, 255, 0.62);
        font-size: clamp(14px, 1.6vw, 15.5px);
        line-height: 1.55;
        max-width: 52ch;
      }
      .chapter .go {
        margin-top: 10px;
        display: inline-block;
        font-size: 14px;
        font-weight: 600;
        color: color-mix(in srgb, var(--c2) 70%, #fff);
      }
      @media (max-width: 640px) {
        .chapter { flex-direction: row; align-items: flex-start; gap: 16px; }
        .chapter .portrait { width: 86px; height: 106px; border-radius: 18px; }
        .chapter .bubble-reply { margin-left: 10px; }
      }

      /* chapters float up on reveal */
      .rv {
        opacity: 0;
        transform: translateY(26px);
        transition: opacity 0.65s ease, transform 0.65s cubic-bezier(0.2, 0.7, 0.2, 1);
      }
      .rv.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) { .rv { opacity: 1; transform: none; } }

      /* --- pillars bento --- */
      .pillars {
        max-width: 1080px;
        margin: 0 auto;
        padding: 8vh 24px 6vh;
      }
      .pillars-head { text-align: center; margin-bottom: clamp(28px, 4vw, 46px); }
      .pillars-head .kicker {
        font-size: 12px; font-weight: 700; letter-spacing: 0.24em; text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45); margin-bottom: 12px;
      }
      .pillars-head h2 {
        font-size: clamp(26px, 4.4vw, 46px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.08;
      }
      .pillars-head h2 em {
        font-family: 'Instrument Serif', Georgia, serif; font-style: italic; font-weight: 400;
        padding-right: 0.06em;
      }
      .bento { display: grid; grid-template-columns: repeat(12, 1fr); gap: 18px; }
      .b7 { grid-column: span 7; } .b5 { grid-column: span 5; }
      .bcell {
        border-radius: 24px; overflow: hidden; position: relative;
        background: #101014; border: 1px solid rgba(255, 255, 255, 0.08);
        display: flex; flex-direction: column;
      }
      .bcell .art { position: relative; height: 210px; flex: 0 0 auto; }
      .bcell .btxt { padding: 4px 26px 24px; }
      .bcell h3 { font-size: 21px; letter-spacing: -0.02em; margin-bottom: 6px; font-weight: 700; }
      .bcell p { color: rgba(255, 255, 255, 0.62); font-size: 14.5px; line-height: 1.55; max-width: 46ch; }
      .bcell p em { font-family: 'Instrument Serif', Georgia, serif; font-style: italic; color: #fff; }
      @media (max-width: 780px) {
        .b7, .b5 { grid-column: span 12; }
        .bcell .art { height: 180px; }
      }

      /* voice: equalizer */
      .art-voice { background: radial-gradient(90% 120% at 50% 110%, rgba(255, 107, 53, 0.26), transparent 70%); display: flex; align-items: center; justify-content: center; gap: 7px; }
      .art-voice .bar { width: 9px; border-radius: 99px; background: linear-gradient(180deg, #ffdc83, #ff6b35); height: 34%; }
      @keyframes eq { 0%, 100% { transform: scaleY(0.35); } 50% { transform: scaleY(1); } }

      /* memory: constellation */
      .art-memory { background: radial-gradient(80% 120% at 80% -10%, rgba(124, 58, 237, 0.28), transparent 70%); }
      .art-memory svg { position: absolute; inset: 0; width: 100%; height: 100%; }
      .art-memory .st { fill: #fff; }
      @keyframes twinkle { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }
      .art-memory .cl { stroke: rgba(255, 255, 255, 0.28); stroke-width: 1; fill: none; stroke-dasharray: 220; stroke-dashoffset: 220; }
      @keyframes draw { 40% { stroke-dashoffset: 0; } 85% { stroke-dashoffset: 0; opacity: 1; } 100% { stroke-dashoffset: 0; opacity: 0; } }

      /* craft: coach tiles */
      .art-craft { display: flex; align-items: center; justify-content: center; background: radial-gradient(90% 130% at 15% -10%, rgba(255, 171, 173, 0.15), transparent 70%); }
      .art-craft .tiles { display: grid; grid-template-columns: repeat(3, 56px); gap: 11px; }
      .art-craft .tile {
        width: 56px; height: 56px; border-radius: 14px; object-fit: cover;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.55); display: block;
      }
      .art-craft .tile:nth-child(5) { transform: rotate(-9deg) translateY(-9px); box-shadow: 0 20px 36px rgba(0, 0, 0, 0.7); }
      @keyframes tile-bob { 0%, 100% { transform: rotate(-9deg) translateY(-9px); } 50% { transform: rotate(-6deg) translateY(-15px); } }

      /* rigor: falling astro glyphs */
      .art-rigor { background: radial-gradient(80% 130% at 50% -20%, rgba(201, 161, 74, 0.22), transparent 72%); display: flex; justify-content: space-around; padding: 0 8%; overflow: hidden; }
      .art-rigor .fcol { display: flex; flex-direction: column; gap: 17px; font-family: ui-monospace, Menlo, monospace; font-size: 19px; color: rgba(255, 220, 131, 0.78); }
      @keyframes fall { from { transform: translateY(-55%); } to { transform: translateY(10%); } }

      /* character: typing chat */
      .art-character { background: radial-gradient(90% 130% at 85% 110%, rgba(192, 132, 252, 0.22), transparent 70%); display: flex; flex-direction: column; justify-content: center; gap: 10px; padding: 0 26px; }
      .art-character .cb {
        align-self: flex-start; max-width: 86%;
        background: rgba(255, 255, 255, 0.09); border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 16px 16px 16px 4px; padding: 9px 15px;
        font-size: 14px; font-weight: 600;
      }
      .art-character .cb.reply {
        align-self: flex-end; border-radius: 16px 16px 4px 16px;
        background: linear-gradient(92deg, #c084fc, #ffc1f7); color: #14061f; border: 0;
      }
      .art-character .typing { display: inline-flex; gap: 4px; align-items: center; }
      .art-character .typing i { width: 6px; height: 6px; border-radius: 50%; background: rgba(255, 255, 255, 0.75); }
      @keyframes blink { 0%, 100% { opacity: 0.25; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-2px); } }

      /* pocket: floating phone */
      .art-pocket { background: radial-gradient(90% 140% at 50% 120%, rgba(34, 197, 94, 0.2), transparent 72%); display: flex; align-items: center; justify-content: center; }
      .minphone {
        width: 82px; height: 166px; border-radius: 22px;
        background: linear-gradient(160deg, #191920, #0d0d11);
        border: 1px solid rgba(255, 255, 255, 0.2); position: relative;
      }
      .minphone::before { content: ''; position: absolute; top: 7px; left: 50%; transform: translateX(-50%); width: 27px; height: 8px; border-radius: 99px; background: #000; }
      .minphone::after {
        content: ''; position: absolute; left: 20%; right: 20%; bottom: -24px; height: 11px; border-radius: 50%;
        background: rgba(0, 0, 0, 0.65); filter: blur(6px);
      }
      .minphone .dot { position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); width: 24px; height: 24px; border-radius: 50%; background: linear-gradient(135deg, #ffdc83, #ffabad); box-shadow: 0 0 16px rgba(255, 220, 131, 0.5); }
      @keyframes hover-y { 0%, 100% { transform: translateY(0) rotate(-4deg); } 50% { transform: translateY(-13px) rotate(-2deg); } }
      @keyframes shadow-b { 0%, 100% { transform: scaleX(1); opacity: 0.65; } 50% { transform: scaleX(0.78); opacity: 0.4; } }

      @media (prefers-reduced-motion: no-preference) {
        .art-voice .bar { animation: eq 1.15s ease-in-out infinite; }
        .art-memory .st { animation: twinkle 3.2s ease-in-out infinite; }
        .art-memory .cl { animation: draw 6s ease forwards infinite; }
        .art-craft .tile:nth-child(5) { animation: tile-bob 4.5s ease-in-out infinite; }
        .art-rigor .fcol { animation: fall linear infinite; }
        .art-character .typing i { animation: blink 1.2s ease-in-out infinite; }
        .art-character .typing i:nth-child(2) { animation-delay: 0.18s; }
        .art-character .typing i:nth-child(3) { animation-delay: 0.36s; }
        .minphone { animation: hover-y 5s ease-in-out infinite; }
        .minphone::after { animation: shadow-b 5s ease-in-out infinite; }
      }
      @media (prefers-reduced-motion: reduce) {
        .art-memory .cl { stroke-dashoffset: 0; }
      }

      /* --- proof band --- */
      .proof {
        text-align: center;
        padding: 6vh 24px 14vh;
        max-width: 760px;
        margin: 0 auto;
      }
      .proof .laurel {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
        margin-bottom: 18px;
      }
      .proof h2 {
        font-size: clamp(26px, 4vw, 44px);
        font-weight: 500;
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 14px;
      }
      .proof h2 em {
        font-family: 'Instrument Serif', Georgia, serif;
        font-weight: 400;
        background: linear-gradient(92deg, #ffdc83, #ffabad, #ffc1f7);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        padding-right: 0.06em;
      }
      .proof p { color: rgba(255, 255, 255, 0.6); font-size: 16px; margin-bottom: 34px; }
    </style>
  </head>
  <body>
    <div class="card">
      <canvas id="stars" aria-hidden="true"></canvas>
      <div class="nebula" aria-hidden="true"></div>
      <div class="fade-l" aria-hidden="true"></div>
      <div class="fade-r" aria-hidden="true"></div>
      <div class="fade-t" aria-hidden="true"></div>

      <div class="content">
        <img class="logo-mark" src={withBase('/home/logo.png')} alt="Bliss Coach logo" width="52" height="52" />
        <h1>
          <span class="t-desktop">Building the world's largest<br />portfolio of <span class="serif">AI coaching apps</span></span>
          <span class="t-mobile">Building the world's<br />largest portfolio of<br /><span class="serif">AI coaching apps</span></span>
        </h1>
        <p class="sub">Specialized AI coaches<br />for every area of life.</p>
        <div class="cta-wrap">
          <span class="cta-beam" aria-hidden="true"></span>
          <a class="cta" href="https://apps.apple.com/us/developer/bliss-coach/id1628409883">Get Started</a>
        </div>
      </div>

      <div class="horizon">
        <div class="disc" aria-hidden="true"></div>
        <div class="flare" aria-hidden="true"></div>
        <nav class="avatars" aria-label="Our apps">
          {avatars.map((a) => (
            <a href={withBase(a.href)} title={a.alt}>
              <img src={withBase(`/home/${a.src}`)} alt={a.alt} style={`object-position:${a.pos}`} width="54" height="66" loading="eager" />
            </a>
          ))}
        </nav>
      </div>
    </div>

    <div class="story" id="story">
      <!-- manifesto: fills in word by word as you scroll -->
      <section class="manifesto" id="manifesto" aria-label="Our manifesto">
        {manifesto.map((sentence) => (
          <p>
            {sentence.split(' ').map((word) => (
              <><span class="w">{word}</span>{' '}</>
            ))}
          </p>
        ))}
      </section>

      <!-- six coaches, six chapters -->
      <section class="coaches" id="coaches" aria-label="Meet the coaches">
        <div class="coaches-kicker rv">Meet the coaches</div>
        {coaches.map((c) => (
          <a class="chapter rv" href={withBase(`/${c.slug}/`)} style={`--c1:${c.c1};--c2:${c.c2}`}>
            {hasVideo(c.slug) ? (
              <video class="portrait" src={withBase(`/home/video/${c.slug}.mp4`)} muted loop playsinline autoplay preload="metadata" poster={withBase(`/home/${c.img}`)} aria-label={`${c.name} standing`} width="148" height="180"></video>
            ) : (
              <img class="portrait" src={withBase(`/home/${c.img}`)} alt={`${c.name} portrait`} style={`object-position:${c.pos}`} width="148" height="180" loading="lazy" />
            )}
            <div class="txt">
              <span class="bubble">{c.line}</span>
              {c.reply && <><br /><span class="bubble-reply">{c.reply}</span></>}
              <h3><img class="app-ic" src={withBase(`/icons/${c.slug}.jpg`)} alt="" width="30" height="30" loading="lazy" /> {c.name} <span class="craft">{c.craft}</span></h3>
              <p class="blurb">{c.blurb}</p>
              <span class="go">Meet {c.name} →</span>
            </div>
          </a>
        ))}
      </section>

      <!-- the pillars: what makes every coach great -->
      <section class="pillars" aria-label="The pillars of every coach">
        <div class="pillars-head rv">
          <div class="kicker">Why they work</div>
          <h2>The pillars of <em>every coach</em></h2>
        </div>
        <div class="bento">

          <div class="bcell b7 rv">
            <div class="art art-voice" aria-hidden="true">
              <div class="bar" style="animation-delay:0s"></div><div class="bar" style="animation-delay:.12s"></div>
              <div class="bar" style="animation-delay:.24s"></div><div class="bar" style="animation-delay:.06s"></div>
              <div class="bar" style="animation-delay:.3s"></div><div class="bar" style="animation-delay:.18s"></div>
              <div class="bar" style="animation-delay:.02s"></div><div class="bar" style="animation-delay:.26s"></div>
              <div class="bar" style="animation-delay:.1s"></div><div class="bar" style="animation-delay:.22s"></div>
              <div class="bar" style="animation-delay:.34s"></div><div class="bar" style="animation-delay:.16s"></div>
            </div>
            <div class="btxt">
              <h3>Voice</h3>
              <p>You talk. She talks back. Every session is a <em>real conversation</em> — out loud, in real time, no typing required.</p>
            </div>
          </div>

          <div class="bcell b5 rv">
            <div class="art art-memory" aria-hidden="true">
              <svg viewBox="0 0 400 210">
                <path class="cl" d="M60 160 L140 70 L230 115 L330 45" />
                <circle class="st" cx="60" cy="160" r="3" style="animation-delay:0s"/>
                <circle class="st" cx="140" cy="70" r="4" style="animation-delay:.6s"/>
                <circle class="st" cx="230" cy="115" r="3" style="animation-delay:1.2s"/>
                <circle class="st" cx="330" cy="45" r="4" style="animation-delay:1.8s"/>
                <circle class="st" cx="90" cy="50" r="2" style="animation-delay:.3s"/>
                <circle class="st" cx="300" cy="150" r="2" style="animation-delay:.9s"/>
                <circle class="st" cx="360" cy="105" r="2" style="animation-delay:1.5s"/>
              </svg>
            </div>
            <div class="btxt">
              <h3>Memory</h3>
              <p>Your coach remembers — goals, slip-ups, wins. <em>Session 12 builds on session 11.</em></p>
            </div>
          </div>

          <div class="bcell b5 rv">
            <div class="art art-craft" aria-hidden="true">
              <div class="tiles">
                <img class="tile" src={withBase('/icons/sofia.jpg')} alt="" width="56" height="56" loading="lazy" />
                <img class="tile" src={withBase('/icons/amelie.jpg')} alt="" width="56" height="56" loading="lazy" />
                <img class="tile" src={withBase('/icons/alex.jpg')} alt="" width="56" height="56" loading="lazy" />
                <img class="tile" src={withBase('/icons/charm.jpg')} alt="" width="56" height="56" loading="lazy" />
                <img class="tile" src={withBase('/icons/mila.jpg')} alt="" width="56" height="56" loading="lazy" />
                <img class="tile" src={withBase('/icons/astra.jpg')} alt="" width="56" height="56" loading="lazy" />
              </div>
            </div>
            <div class="btxt">
              <h3>Craft</h3>
              <p>One coach, one craft. Sofia does Spanish. Mila does meals. <em>Nobody does everything.</em></p>
            </div>
          </div>

          <div class="bcell b7 rv">
            <div class="art art-rigor" aria-hidden="true">
              <div class="fcol" style="animation-duration:14s"><span>♄</span><span>3</span><span>☽</span><span>7</span><span>♀</span><span>1</span><span>☉</span><span>9</span><span>♄</span><span>3</span><span>☽</span><span>7</span></div>
              <div class="fcol" style="animation-duration:22s"><span>2</span><span>♆</span><span>8</span><span>☿</span><span>5</span><span>♃</span><span>0</span><span>♂</span><span>2</span><span>♆</span><span>8</span><span>☿</span></div>
              <div class="fcol" style="animation-duration:11s"><span>☉</span><span>6</span><span>♓</span><span>4</span><span>♌</span><span>8</span><span>☽</span><span>2</span><span>☉</span><span>6</span><span>♓</span><span>4</span></div>
              <div class="fcol" style="animation-duration:18s"><span>1</span><span>♀</span><span>9</span><span>♎</span><span>3</span><span>☿</span><span>7</span><span>♑</span><span>1</span><span>♀</span><span>9</span><span>♎</span></div>
              <div class="fcol" style="animation-duration:26s"><span>♃</span><span>5</span><span>☽</span><span>0</span><span>♒</span><span>6</span><span>♄</span><span>4</span><span>♃</span><span>5</span><span>☽</span><span>0</span></div>
            </div>
            <div class="btxt">
              <h3>Rigor</h3>
              <p>Computed, not recycled. Plans, corrections and horoscopes are built from <em>your data, fresh every day.</em></p>
            </div>
          </div>

          <div class="bcell b7 rv">
            <div class="art art-character">
              <span class="cb">Okay — tell me about the interview. What's the company?</span>
              <span class="cb reply">A fintech startup, final round 😬</span>
              <span class="cb"><span class="typing"><i></i><i></i><i></i></span></span>
            </div>
            <div class="btxt">
              <h3>Character</h3>
              <p>A coach is a person, not a chatbot. Ours have <em>faces, moods and opinions</em> — and they use them.</p>
            </div>
          </div>

          <div class="bcell b5 rv">
            <div class="art art-pocket" aria-hidden="true">
              <div class="minphone"><div class="dot"></div></div>
            </div>
            <div class="btxt">
              <h3>Pocket</h3>
              <p>Coaching used to cost $200 an hour. Now it lives in your pocket — <em>ten minutes a day,</em> wherever you are.</p>
            </div>
          </div>

        </div>
      </section>

      <!-- proof -->
      <section class="proof" aria-label="Get the apps">
        <div class="laurel rv">Live on the App Store</div>
        <h2 class="rv">Six coaches, already <em>taking conversations</em></h2>
        <p class="rv">Every conversation is voice-first, personal, and gets better the more you talk.</p>
        <div class="cta-wrap rv" style="display:inline-block">
          <span class="cta-beam" aria-hidden="true"></span>
          <a class="cta" href="https://apps.apple.com/us/developer/bliss-coach/id1628409883">Get the apps</a>
        </div>
      </section>
    </div>

    <footer>
      <nav class="foot-apps" aria-label="Our apps">
        <a href="/sofia/">Sofia</a><a href="/amelie/">Amélie</a><a href="/charm/">Charm</a><a href="/alex/">Alex</a><a href="/mila/">Mila</a><a href="/astra/">Astra</a>
      </nav>
      <span>© Bliss Coach</span>
    </footer>

    <script>
      // Twinkling starfield, same spirit as the Framer canvas.
      const canvas = document.getElementById('stars') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let stars: { x: number; y: number; r: number; a: number; s: number; vx: number; vy: number }[] = [];

      function seed() {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = canvas.offsetWidth * dpr;
        canvas.height = canvas.offsetHeight * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const n = Math.round((canvas.offsetWidth * canvas.offsetHeight) / 9000);
        stars = Array.from({ length: n }, () => ({
          x: Math.random() * canvas.offsetWidth,
          y: Math.random() * canvas.offsetHeight * 0.8,
          r: Math.random() * 1.1 + 0.4,
          a: Math.random() * 0.55 + 0.15,
          s: Math.random() * 0.004 + 0.001,
          vx: (Math.random() - 0.5) * 0.1,
          vy: -(Math.random() * 0.05 + 0.012),
        }));
      }

      let t = 0;
      function draw() {
        t++;
        ctx.clearRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);
        for (const st of stars) {
          if (!reduceMotion) {
            st.x += st.vx;
            st.y += st.vy;
            if (st.y < -2) { st.y = canvas.offsetHeight * 0.8 + 2; st.x = Math.random() * canvas.offsetWidth; }
            if (st.x < -2) st.x = canvas.offsetWidth + 2;
            else if (st.x > canvas.offsetWidth + 2) st.x = -2;
          }
          const tw = st.a + Math.sin(t * st.s * 60) * 0.18;
          ctx.globalAlpha = Math.max(0.05, Math.min(0.8, tw));
          ctx.beginPath();
          ctx.arc(st.x, st.y, st.r, 0, Math.PI * 2);
          ctx.fillStyle = '#ffffff';
          ctx.fill();
        }
        requestAnimationFrame(draw);
      }

      seed();
      draw();
      window.addEventListener('resize', seed);

      // ---- the story ----
      if (!reduceMotion) {
        // words fill in, scroll-linked (and reversible), like reading aloud
        const words = Array.from(document.querySelectorAll('#manifesto .w'));
        const manifesto = document.getElementById('manifesto')!;
        let ticking = false;
        function paintWords() {
          ticking = false;
          const r = manifesto.getBoundingClientRect();
          const vh = window.innerHeight;
          // progress: 0 when section enters, 1 when its bottom nears the top third
          const total = r.height - vh * 0.25;
          const gone = Math.min(Math.max(vh * 0.75 - r.top, 0), total);
          const p = total > 0 ? gone / total : 1;
          const n = Math.round(p * words.length);
          words.forEach((w, i) => w.classList.toggle('on', i < n));
        }
        window.addEventListener('scroll', () => {
          if (!ticking) { ticking = true; requestAnimationFrame(paintWords); }
        }, { passive: true });
        paintWords();

        // chapters & proof float up
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.rv').forEach((el) => io.observe(el));

        // backdrop hue shifts with the chapter you're in
        const story = document.getElementById('story')!;
        const phases = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            story.classList.toggle('phase-manifesto', e.target.id === 'manifesto');
            story.classList.toggle('phase-coaches', e.target.id !== 'manifesto');
          }
        }, { threshold: 0.25 });
        phases.observe(manifesto);
        phases.observe(document.getElementById('coaches')!);
      } else {
        document.querySelectorAll('#manifesto .w').forEach((w) => w.classList.add('on'));
      }
    </script>
  </body>

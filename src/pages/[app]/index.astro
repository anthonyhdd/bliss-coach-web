---
import fs from 'node:fs';
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import AppStoreButton from '../../components/AppStoreButton.astro';
import CelestialCrest from '../../components/CelestialCrest.astro';
import { APPS, withBase } from '../../config/apps';
import { SHOWCASE } from '../../config/showcase';
import { PSEO_SECTIONS } from '../../config/pseo';

export function getStaticPaths() {
  return Object.keys(APPS).map((app) => ({ params: { app } }));
}

const { app: slug } = Astro.params;
const app = APPS[slug!];
const show = SHOWCASE[slug!];
// the coach's real standing loop plays inside the phone when available
const phoneVideo = fs.existsSync(`public/home/video/${slug}.mp4`) ? `/home/video/${slug}.mp4` : null;

const posts = (await getCollection('blog', (p) => p.data.app === slug && !p.data.draft && p.data.lang === 'en')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const pseoSection = PSEO_SECTIONS[slug!];
const pseoCount = (await getCollection('pseo', (p) => p.data.app === slug && !p.data.draft)).length;

const brandStyle = `--brand-1:${app.gradient[0]};--brand-2:${app.gradient[1]};--brand-3:${app.gradient[2]};--accent:${app.accent};--on-gradient:${app.onGradient}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: app.name,
  operatingSystem: 'iOS',
  applicationCategory: 'EducationApplication',
  description: app.subtitle,
  url: `https://bliss-coach.com/${app.slug}/`,
  installUrl: app.appStoreUrl,
  author: { '@type': 'Organization', name: 'Bliss Coach' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD', description: 'Free download with in-app subscription' },
};
---

<Base
  title={`${app.name} — ${app.tagline} | Bliss Coach`}
  description={app.subtitle}
  appStoreId={app.appStoreId}
  ogImage={`/icons/${app.slug}.jpg`}
  activeApp={app.slug}
  soloHeader={{ slug: app.slug, name: app.name, appStoreUrl: app.appStoreUrl, comingSoon: app.comingSoon }}
  brandStyle={brandStyle}
  jsonLd={jsonLd}
>
  <div style={brandStyle}>
    <div class="brand-strip" aria-hidden="true"></div>
    {app.comingSoon && (
      <div class="app-banner"><span><i>&gt;</i> {app.name} is in the lab — <mark>coming soon</mark> to the App Store <b>✦</b></span></div>
    )}

    <!-- hero: pitch + the product itself in a phone -->
    <section class="app-hero2">
      <div class="glow" aria-hidden="true"></div>
      <div class="container inner2">
        <div class="pitch">
          <img class="hero-appicon" src={withBase(`/icons/${app.slug}.jpg`)} alt={`${app.name} app icon`} width="64" height="64" loading="eager" />
          <div class="kicker">{app.category}</div>
          <h1>{show.heroTitle} <em class="serif-em">{show.heroEm}</em></h1>
          <p class="sub">{show.heroSub}</p>
          <div class="hero-cta">
            {app.comingSoon ? (
              <span class="coming-soon">Coming soon to the App Store</span>
            ) : (
              <>
                <AppStoreButton href={app.appStoreUrl} />
                {/* same friction-reducers as the app's own welcome screen */}
                <p class="cta-note">Free to download · No credit card to start</p>
              </>
            )}
          </div>
          {(show.stat || show.laurels) && (
            <div class="cred">
              {show.stat && (
                <span class="stat"><strong>{show.stat.value}</strong> {show.stat.label}</span>
              )}
              {show.laurels?.map((l) => <span class="laurel-chip">{l}</span>)}
            </div>
          )}
        </div>

        <div class="phone-wrap">
          <div class="hprop hprop-paper" aria-hidden="true">
            {app.slug === 'sofia' && (
              <svg class="paper-art" viewBox="0 0 120 26">
                <path d="M12 2l2.7 5.5 6 .9-4.3 4.2 1 6L12 15.7 6.6 18.6l1-6L3.3 8.4l6-.9Z" fill="#e05a3a" />
                {[30,34,37,42,45,50,53,58,61,66,69,74,78,82,86,91,94,99,103,108].map((x, i) => (
                  <rect x={x} y="4" width={i % 3 === 0 ? 2.6 : 1.3} height="18" fill="#26241d" />
                ))}
              </svg>
            )}
            {app.slug === 'amelie' && (
              <svg class="paper-art" viewBox="0 0 120 30" fill="none" stroke="#26241d" stroke-width="1.4" stroke-linecap="round">
                <path d="M18 28 C21 18 24 11 26 3 M34 28 C31 18 28 11 26 3" />
                <path d="M21 20 H31 M19.5 24.5 H32.5 M23 12.5 H29" />
                <path d="M14 28 H38" />
                <circle cx="26" cy="2.5" r="1.6" fill="#DB2777" stroke="none" />
                <g fill="#26241d" stroke="none">
                  <circle cx="58" cy="15" r="3.4" />
                  <circle cx="72" cy="15" r="3.4" />
                  <circle cx="86" cy="15" r="3.4" fill="none" stroke="#26241d" stroke-width="1.4" />
                  <circle cx="100" cy="15" r="3.4" fill="none" stroke="#26241d" stroke-width="1.4" />
                </g>
              </svg>
            )}
            {app.slug === 'charm' && (
              <svg class="paper-art" viewBox="0 0 120 30" fill="none" stroke="#26241d" stroke-width="1.5">
                <circle cx="44" cy="15" r="11" />
                <circle cx="76" cy="15" r="11" />
                <path d="M60 20.5c-3.2-2-5-4-5-6.2 0-1.8 1.4-3.1 3-3.1 1 0 1.7.4 2 1 .3-.6 1-1 2-1 1.6 0 3 1.3 3 3.1 0 2.2-1.8 4.2-5 6.2Z" fill="#C9A14A" stroke="none" />
                <path d="M14 8l1.2 2.5L18 11l-2.4 1.4L15 15l-1-2.6L11.5 11l2.6-.5ZM104 6l1.5 3 3.2.6-3 1.7-.7 3.2-1.2-3.2-3.3-.6 3.2-1.7Z" fill="#26241d" stroke="none" />
              </svg>
            )}
            {app.slug === 'alex' && (
              <svg class="paper-art" viewBox="0 0 120 30" fill="none">
                <path d="M8 21 C16 6 22 26 32 13 S 50 8 58 17" stroke="#26241d" stroke-width="1.6" stroke-linecap="round" />
                <g transform="rotate(-7 92 15)">
                  <rect x="72" y="6" width="40" height="17" rx="3" stroke="#5a63c8" stroke-width="1.5" />
                  <text x="92" y="18" font-size="8.5" text-anchor="middle" fill="#5a63c8" font-weight="700" letter-spacing="1.5">SIGNED</text>
                </g>
              </svg>
            )}
            {app.slug === 'mila' && (
              <svg class="paper-art" viewBox="0 0 120 30">
                <path d="M30 24 C46 32 70 24 80 8 C62 0 40 6 30 24 Z" fill="#e4f2e0" stroke="#2e7d43" stroke-width="1.4" />
                <circle cx="46" cy="18" r="4.6" fill="#7cc47f" stroke="#2e7d43" stroke-width="1.2" />
                <circle cx="58" cy="15.5" r="4.6" fill="#7cc47f" stroke="#2e7d43" stroke-width="1.2" />
                <circle cx="69" cy="12" r="4.6" fill="#7cc47f" stroke="#2e7d43" stroke-width="1.2" />
                <path d="M80 8 C84 4 88 3 92 4 C90 8 86 10 82 10" fill="#9ed4a0" stroke="#2e7d43" stroke-width="1.2" />
              </svg>
            )}
            {app.slug === 'astra' && (
              <svg class="paper-art" viewBox="0 0 120 30">
                <path d="M60 2 A13 13 0 1 0 60 28 A10 10 0 1 1 60 2 Z" fill="#c9a14a" />
                <path d="M86 6l1.4 3 3.2.6-3 1.7-.6 3.3-1.3-3.2-3.3-.7 3.2-1.6ZM30 16l1 2.2 2.4.4-2.2 1.3-.5 2.4-1-2.4-2.4-.5 2.3-1.2Z" fill="#26241d" />
              </svg>
            )}
            <b>{show.paper.title}</b>
            <span>{show.paper.line}</span>
          </div>
          <span class="hprop hprop-sticker" aria-hidden="true">{show.sticker}</span>
          <div class="phone" role="img" aria-label={`${app.name} app — “${show.screenLine}”`}>
            <div class="screen">
              {show.screenVariant === 'sky' ? (
                <div class="sky" aria-hidden="true">
                  <div class="sky-crest"><CelestialCrest size={170} /></div>
                </div>
              ) : phoneVideo ? (
                <video src={withBase(phoneVideo)} muted loop playsinline autoplay preload="metadata" poster={withBase(`/home/${show.screenImg}`)} width="290" height="620" aria-label={`${app.name} standing`}></video>
              ) : (
                <img src={withBase(`/home/${show.screenImg}`)} alt="" style={`object-position:${show.screenPos}`} width="290" height="620" loading="eager" />
              )}
              <div class="screen-shade" aria-hidden="true"></div>
              <div class="island" aria-hidden="true"></div>
              <p class="say">{show.screenLine}</p>
              <div class="screen-foot">
                {show.replies && show.replies.map((r) => <span class="reply">{r}</span>)}
                {show.chips && <div class="tool-chips">{show.chips.map((c) => <span class="tool-chip">{c}</span>)}</div>}
                <span class="mic" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M12 3a3 3 0 0 1 3 3v5a3 3 0 0 1-6 0V6a3 3 0 0 1 3-3Z"/><path d="M6 11a6 6 0 0 0 12 0M12 17v4"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- signature line — fills in word by word -->
    <section class="craft-strip">
      <p class="serif-line">
        {show.craftLine.split(' ').map((w, i) => (
          <><span class="cw" style={`--i:${i}`}>{w}</span>{' '}</>
        ))}
      </p>
    </section>

    <!-- features as an animated bento — art types themed per app -->
    <section class="section container">
      <div class="fbento">
        {app.features.map((f, i) => {
          const art = show.featureArts[i];
          const span = i === 0 ? 'fb7' : i === 1 ? 'fb5' : 'fb12';
          return (
            <div class={`fcell ${span} feature`}>
              <div class={`fart fart-${art}`} aria-hidden="true">
                {art === 'wave' && (
                  <>{[0, 0.12, 0.24, 0.06, 0.3, 0.18, 0.02, 0.26, 0.1, 0.22].map((d) => <span class="fbar" style={`animation-delay:${d}s`}></span>)}</>
                )}
                {art === 'replies' && (
                  <>
                    <span class="fbub">{show.screenLine}</span>
                    {show.replies?.map((r, j) => <span class="fpill" style={`animation-delay:${0.4 + j * 0.35}s`}>{r}</span>)}
                  </>
                )}
                {art === 'chat' && (
                  <>
                    <span class="fbub">{show.screenLine}</span>
                    <span class="fbub me">{show.chatUser ?? 'Tell me more.'}</span>
                    <span class="fbub"><span class="ftyping"><i></i><i></i><i></i></span></span>
                  </>
                )}
                {art === 'track' && (
                  <div class="ftrack">
                    {[1, 2, 3, 4].map((n) => <span class={`fstep${n < 3 ? ' done' : n === 3 ? ' now' : ''}`}>{n}</span>)}
                  </div>
                )}
                {art === 'scan' && (
                  <div class="fscan"><div class="fdoc"></div><div class="fbeam"></div></div>
                )}
                {art === 'fix' && (
                  <div class="ffix">
                    <i class="l1"></i><i class="l2"></i><i class="l3"></i>
                    <span class="fx-under"></span>
                    <svg class="fx-check" viewBox="0 0 24 24"><path d="M5 13l4 4 9-10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                )}
                {art === 'chips' && (
                  <div class="fchips">{show.chips?.map((c, j) => <span class="fchip" style={`animation-delay:${j * 0.5}s`}>{c}</span>)}</div>
                )}
                {art === 'ring' && (
                  <svg class="fring" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="48" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="9" />
                    <circle class="arc" cx="60" cy="60" r="48" fill="none" stroke="var(--accent)" stroke-width="9" stroke-linecap="round" stroke-dasharray="302" stroke-dashoffset="90" transform="rotate(-90 60 60)" />
                  </svg>
                )}
                {art === 'glyphs' && (
                  <>{['14s', '22s', '11s', '18s'].map((dur, j) => (
                    <div class="fcol" style={`animation-duration:${dur}`}>{['♄', '3', '☽', '7', '♀', '1', '☉', '9', '♄', '3', '☽', '7'].map((g) => <span>{g}</span>)}</div>
                  ))}</>
                )}
                {art === 'orbit' && (
                  <div class="forbit"><span class="fsun"></span><span class="fpath"></span><span class="fmoon"></span></div>
                )}
                {art === 'crest' && (
                  <div class="fcrest"><CelestialCrest size={150} /></div>
                )}
              </div>
              <div class="ftxt">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    {show.quotes && show.quotes.length > 0 && (
      <section class="section container quotes">
        <div class="quote-grid" data-count={show.quotes.length}>
          {show.quotes.map((q) => (
            <figure class="quote feature">
              <span class="q-avatar">{q.name[0]}</span>
              <blockquote>“{q.text}”</blockquote>
              <figcaption>— {q.name}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )}

    {pseoCount > 0 && (
      <section class="section container">
        <a class="article-card" href={withBase(`/${app.slug}/${pseoSection.base}/`)} style="display:block">
          <h3>{pseoSection.hubTitle} ({pseoCount})</h3>
          <p>{pseoSection.hubIntro}</p>
          <span class="read">Browse all →</span>
        </a>
      </section>
    )}

    {posts.length > 0 && (
      <section class="section guides-band">
        <div class="container">
          <h2>{app.blogTitle}</h2>
          <p class="lead">{app.blogDescription}</p>
        </div>
        <div class="gmarquee" aria-label="Guides">
          <div class="gmarquee-track">
            {[...posts.slice(0, 8), ...posts.slice(0, 8)].map((post) => (
              <a class="article-card gcard" href={withBase(`/${app.slug}/blog/${post.id.split('/')[1]}/`)}>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <span class="read">Read the guide →</span>
              </a>
            ))}
          </div>
        </div>
        <div class="container" style="margin-top:26px">
          <a class="btn btn-ghost" href={withBase(`/${app.slug}/blog/`)}>All articles</a>
        </div>
      </section>
    )}

    {!app.comingSoon && (
      <a class="sticky-cta" href={app.appStoreUrl} aria-label={`Download ${app.name} on the App Store`}>
        <img src={withBase(`/icons/${app.slug}.jpg`)} alt="" width="30" height="30" loading="lazy" />
        <span class="sc-txt"><b>Get {app.name}</b> — free on the App Store</span>
        <span class="sc-btn">Download</span>
      </a>
    )}

    <!-- final invitation -->
    <section class="cta-band">
      <div class="container inner-cta">
        <img src={withBase(`/icons/${app.slug}.jpg`)} alt="" width="72" height="72" loading="lazy" />
        <div class="txt">
          <h2>Meet {app.name}.</h2>
          <p>{app.tagline}.</p>
        </div>
        {app.comingSoon ? (
          <span class="coming-soon">Coming soon to the App Store</span>
        ) : (
          <AppStoreButton href={app.appStoreUrl} />
        )}
      </div>
    </section>
  </div>

  <script>
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // the page dresses in the app's color as the signature strip passes (home pattern)
    const stripEl = document.querySelector('.craft-strip');
    if (stripEl) {
      document.body.style.transition = 'background-color 1.2s ease';
      const worlds = new IntersectionObserver((es) => {
        for (const e of es) {
          if (e.isIntersecting) {
            const b1 = getComputedStyle(document.body).getPropertyValue('--brand-1').trim();
            if (b1) document.body.style.backgroundColor = `color-mix(in srgb, ${b1} 7%, #0b0b0f)`;
          } else {
            document.body.style.removeProperty('background-color');
          }
        }
      }, { threshold: 0.4 });
      worlds.observe(stripEl);
    }

    // sticky mobile CTA appears once the hero CTA scrolls out of view
    const heroCta = document.querySelector('.hero-cta');
    const sticky = document.querySelector('.sticky-cta');
    if (heroCta && sticky) {
      const io = new IntersectionObserver((es) => {
        for (const e of es) sticky.classList.toggle('on', !e.isIntersecting && e.boundingClientRect.top < 0);
      }, { threshold: 0 });
      io.observe(heroCta);
    }

    // signature line fills in as it enters the viewport
    const strip = document.querySelector('.craft-strip');
    if (strip) {
      if (reduce) strip.classList.add('lit');
      else {
        const io = new IntersectionObserver((es) => {
          for (const e of es) if (e.isIntersecting) { strip.classList.add('lit'); io.disconnect(); }
        }, { threshold: 0.5 });
        io.observe(strip);
      }
    }

  </script>
</Base>

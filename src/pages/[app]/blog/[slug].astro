---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { APPS, LANG_NAMES, withBase } from '../../../config/apps';
import { PSEO_SECTIONS } from '../../../config/pseo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => !p.data.draft && p.data.lang === 'en');
  return posts.map((post) => ({
    params: { app: post.data.app, slug: post.id.split('/')[1] },
    props: { post },
  }));
}

const { post } = Astro.props;

/**
 * Build FAQPage JSON-LD from the article's visible "## … FAQ" section
 * (bold-question + answer-paragraph format). Google requires the markup to
 * mirror on-page content — we only emit what the reader actually sees.
 */
function extractFaq(body: string): { q: string; a: string }[] {
  const sec = /^##[^\n]*FAQ[^\n]*$([\s\S]*?)(?=^## |^---$|\s*$(?![\s\S]))/m.exec(body);
  if (!sec) return [];
  const out: { q: string; a: string }[] = [];
  const strip = (t: string) =>
    t
      .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
      .replace(/[*_`]/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  let m: RegExpExecArray | null;
  // "### Question" format (older articles)
  const h3rx = /^### (.+)$\n([\s\S]*?)(?=^### |^## |^---$|\s*$(?![\s\S]))/gm;
  while ((m = h3rx.exec(sec[1])) !== null) {
    const q = strip(m[1]);
    const a = strip(m[2]);
    if (q && a) out.push({ q, a });
  }
  if (out.length) return out;
  // "**Question?**" bold format (newer articles)
  const rx = /\*\*(.+?)\*\*\s*\n?([\s\S]*?)(?=\n\*\*|\n---|\n## |$)/g;
  while ((m = rx.exec(sec[1])) !== null) {
    const q = strip(m[1]);
    const a = strip(m[2]);
    if (q && a) out.push({ q, a });
  }
  return out;
}
const faq = extractFaq(post.body ?? '');

const app = APPS[post.data.app];
const { Content } = await render(post);

const related = (await getCollection('blog', (p) => p.data.app === post.data.app && !p.data.draft && p.data.lang === 'en' && p.id !== post.id))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

// Cross-silo internal links: surface this app's pSEO hub + a few topical item
// pages so the blog and pSEO content pools link into each other instead of
// each staying in its own silo. Deterministic across builds: rank by shared
// keywords (topical signal), tie-break alphabetically by slug.
const section = PSEO_SECTIONS[post.data.app];
const postKw = new Set(post.data.keywords.map((k) => k.toLowerCase()));
const relatedPseo = (await getCollection('pseo', (p) => p.data.app === post.data.app && !p.data.draft))
  .map((e) => ({ entry: e, slug: e.id.split('/')[1] }))
  .sort((a, b) => {
    const score = (x: { entry: typeof a.entry }) =>
      x.entry.data.keywords.reduce((n, k) => n + (postKw.has(k.toLowerCase()) ? 1 : 0), 0);
    return score(b) - score(a) || a.slug.localeCompare(b.slug);
  })
  .slice(0, 3);

const brandStyle = `--brand-1:${app.gradient[0]};--brand-2:${app.gradient[1]};--brand-3:${app.gradient[2]};--accent:${app.accent};--on-gradient:${app.onGradient}`;
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const slug = post.id.split('/')[1];
const canonicalPath = `/${app.slug}/blog/${slug}/`;

// hreflang alternates: translated twins point at this slug via translationOf
const translations = await getCollection(
  'blog',
  (p) => p.data.app === post.data.app && !p.data.draft && p.data.lang !== 'en' && p.data.translationOf === slug,
);
const alternates = translations.length
  ? [
      { hreflang: 'en', href: `https://bliss-coach.com${canonicalPath}` },
      { hreflang: 'x-default', href: `https://bliss-coach.com${canonicalPath}` },
      ...translations.map((t) => ({
        hreflang: t.data.lang,
        href: `https://bliss-coach.com/${t.data.lang}/${app.slug}/blog/${t.id.split('/')[2]}/`,
      })),
    ]
  : [];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
    author: { '@type': 'Organization', name: `${app.name} by Bliss Coach`, url: `https://bliss-coach.com/${app.slug}/` },
    publisher: { '@type': 'Organization', name: 'Bliss Coach', url: 'https://bliss-coach.com/' },
    mainEntityOfPage: `https://bliss-coach.com${canonicalPath}`,
    keywords: post.data.keywords.join(', '),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Bliss Coach', item: 'https://bliss-coach.com/' },
      { '@type': 'ListItem', position: 2, name: app.name, item: `https://bliss-coach.com/${app.slug}/` },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: `https://bliss-coach.com${canonicalPath}` },
    ],
  },
];

if (faq.length >= 2) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  } as any);
}
---

<Base
  title={`${post.data.title} | ${app.name}`}
  description={post.data.description}
  appStoreId={app.appStoreId}
  ogImage={`/icons/${app.slug}.jpg`}
  bodyClass="article-page"
  activeApp={app.slug}
  jsonLd={jsonLd}
  alternates={alternates}
>
  <article style={brandStyle}>
    <div class="brand-strip" aria-hidden="true"></div>
    <header class="article-header">
      <div class="article-hero-tint" aria-hidden="true"></div>
      <a class="app-chip" href={withBase(`/${app.slug}/`)}>
        <img src={withBase(`/icons/${app.slug}.jpg`)} alt="" width="24" height="24" />
        {app.name} · {app.category}
      </a>
      <span class="crumb">
        <a href={withBase(`/${app.slug}/blog/`)}>{app.blogTitle}</a>
      </span>
      {translations.length > 0 && (
        <p class="lang-alts">
          Also available in{' '}
          {translations.map((t, i) => (
            <>
              {i > 0 && <span aria-hidden="true"> · </span>}
              <a
                href={withBase(`/${t.data.lang}/${app.slug}/blog/${t.id.split('/')[2]}/`)}
                hreflang={t.data.lang}
                lang={t.data.lang}
              >
                {LANG_NAMES[t.data.lang] ?? t.data.lang}
              </a>
            </>
          ))}
        </p>
      )}
      <h1>{post.data.title}</h1>
      <p class="meta">
        {fmt(post.data.publishDate)} · by the {app.name} team
      </p>
    </header>

    <div class="prose">
      <Content />
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>Keep reading</h2>
        <div class="article-list">
          {related.map((r) => (
            <a class="article-card" href={withBase(`/${app.slug}/blog/${r.id.split('/')[1]}/`)}>
              <h3>{r.data.title}</h3>
              <p>{r.data.description}</p>
              <span class="read">Read the guide →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {relatedPseo.length > 0 && (
      <section class="related">
        <h2>{section.hubTitle}</h2>
        <p class="related-hub">
          <a href={withBase(`/${app.slug}/${section.base}/`)}>See all {section.itemLabel}s →</a>
        </p>
        <div class="article-list">
          {relatedPseo.map((r) => (
            <a class="article-card" href={withBase(`/${app.slug}/${section.base}/${r.slug}/`)}>
              <h3>{r.entry.data.subject}</h3>
              <p>{r.entry.data.description}</p>
              <span class="read">Read →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <aside class="cta-box">
      <div class="inner">
        <img src={withBase(`/icons/${app.slug}.jpg`)} alt={`${app.name} app icon`} width="72" height="72" />
        <div>
          <h3>{app.tagline}</h3>
          <p>{app.name} — {app.category.toLowerCase()} with an AI coach that talks back. Free to try on iPhone.</p>
        </div>
        <a class="btn" href={app.appStoreUrl}>Get {app.name} free</a>
      </div>
    </aside>
  </article>
</Base>

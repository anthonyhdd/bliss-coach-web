---
// Private-ish video gallery for the founder's phone.
//
// The route segment is NOT in this repo — it comes from the VIDEOS_SLUG build
// secret. This repo is PUBLIC, so hardcoding the path would publish it and
// defeat the whole point. No secret => getStaticPaths returns [] => the page is
// simply not built (safe default for local dev and forks).
//
// Content comes from the content-engine's Supabase manifest at runtime, so this
// page is deployed ONCE and new clips appear on their own. Storage sends
// access-control-allow-origin: *, so the cross-origin fetch works.
export function getStaticPaths() {
  const slug = process.env.VIDEOS_SLUG;
  return slug ? [{ params: { gallery: slug } }] : [];
}

const MANIFEST =
  'https://wbxuxcvxyzmbyshupycs.supabase.co/storage/v1/object/public/shorts/manifest.json';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Vidéos</title>
    <!-- is:global is REQUIRED: Astro scopes <style> by default via a
         data-astro-cid attribute stamped on template elements. The cards below
         are built dynamically with innerHTML, so they never receive that
         attribute and every scoped rule silently misses them. -->
    <style is:global>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #0b0b0d; color: #f4f4f5;
        font: 16px/1.45 -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
        max-width: 520px; margin: 0 auto; padding: 18px 14px 56px;
      }
      h1 { font-size: 21px; letter-spacing: -0.01em; }
      .sub { color: #8b8b93; font-size: 13px; margin-top: 4px; }
      h2 {
        font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;
        color: #c9c9d1; margin: 30px 0 12px; padding-bottom: 7px;
        border-bottom: 1px solid #232329;
      }
      .day { font-size: 12px; color: #6e6e78; margin: 16px 0 8px; letter-spacing: 0.04em; }
      article {
        background: #141418; border: 1px solid #232329; border-radius: 14px;
        padding: 10px; margin-bottom: 14px;
      }
      video {
        width: 100%; aspect-ratio: 9/16; border-radius: 10px;
        background: #000; display: block;
      }
      .hook { margin: 10px 2px; font-size: 15px; font-weight: 600; }
      .row { display: flex; gap: 8px; }
      button {
        flex: 1; appearance: none; border: 1px solid #2e2e36; background: #1c1c22;
        color: #f4f4f5; border-radius: 10px; padding: 11px 8px;
        font-size: 14px; font-weight: 600; font-family: inherit; cursor: pointer;
      }
      button:active { background: #26262e; }
      button.ok { background: #1d4b32; border-color: #2b6b47; }
      button[disabled] { opacity: 0.55; }
      .empty { color: #8b8b93; padding: 40px 0; text-align: center; }
    </style>
  </head>
  <body>
    <h1>Vidéos</h1>
    <p class="sub" id="sub">Chargement…</p>
    <div id="app"></div>

    <script is:inline define:vars={{ MANIFEST }}>
      const app = document.getElementById('app');
      const sub = document.getElementById('sub');
      const esc = (s) =>
        String(s ?? '').replace(/[&<>"']/g, (c) =>
          ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]
        );

      fetch(MANIFEST, { cache: 'no-store' })
        .then((r) => {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        })
        .then((data) => {
          const clips = data.clips || [];
          if (!clips.length) {
            sub.textContent = 'Aucune vidéo.';
            return;
          }
          sub.textContent = `${clips.length} clips · mis à jour ${data.generatedAt || ''}`;

          // Group by app first (that is how they get posted), date second.
          const byApp = new Map();
          for (const c of clips) {
            if (!byApp.has(c.channel)) byApp.set(c.channel, { label: c.channelLabel || c.channel, days: new Map() });
            const days = byApp.get(c.channel).days;
            if (!days.has(c.date)) days.set(c.date, []);
            days.get(c.date).push(c);
          }

          let html = '';
          for (const [, group] of byApp) {
            html += `<h2>${esc(group.label)}</h2>`;
            for (const [date, rows] of group.days) {
              html += `<p class="day">${esc(date)}</p>`;
              for (const c of rows) {
                const caption = [c.hook, c.description, (c.hashtags || []).join(' ')]
                  .filter(Boolean).join('\n\n');
                html += `
                  <article>
                    <video controls playsinline preload="metadata" src="${esc(c.url)}#t=0.1"></video>
                    <p class="hook">${esc(c.hook || '(sans hook)')}</p>
                    <div class="row">
                      <button type="button" data-caption="${esc(caption)}">Copier la légende</button>
                      <button type="button" data-share="${esc(c.url)}">Partager</button>
                    </div>
                  </article>`;
              }
            }
          }
          app.innerHTML = html;
        })
        .catch((e) => {
          sub.textContent = 'Manifeste illisible (' + e.message + ').';
        });

      const flash = (b, txt) => {
        const old = b.textContent;
        b.textContent = txt;
        b.classList.add('ok');
        setTimeout(() => { b.textContent = old; b.classList.remove('ok'); }, 1500);
      };

      document.addEventListener('click', async (e) => {
        const copy = e.target.closest('button[data-caption]');
        if (copy) {
          try {
            await navigator.clipboard.writeText(copy.dataset.caption);
            flash(copy, 'Copié ✓');
          } catch { /* denied or non-secure context: leave the label alone */ }
          return;
        }

        const share = e.target.closest('button[data-share]');
        if (!share) return;

        // A cross-origin <a download> is ignored by browsers, so fetch the bytes
        // and hand them to the native share sheet — on a phone that lands the clip
        // straight into TikTok or Photos, which a download link cannot do.
        const url = share.dataset.share;
        const name = url.split('/').pop() || 'clip.mp4';
        const label = share.textContent;
        share.disabled = true;
        share.textContent = 'Préparation…';
        try {
          const blob = await (await fetch(url)).blob();
          const file = new File([blob], name, { type: 'video/mp4' });
          if (navigator.canShare && navigator.canShare({ files: [file] })) {
            await navigator.share({ files: [file] });
            share.textContent = label;
          } else {
            // Desktop fallback: same-origin blob URL, so download is honoured.
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = name;
            a.click();
            URL.revokeObjectURL(a.href);
            share.textContent = label;
          }
        } catch (err) {
          // AbortError = the user dismissed the share sheet; not a failure.
          share.textContent = err && err.name === 'AbortError' ? label : 'Échec';
          if (err && err.name !== 'AbortError') setTimeout(() => { share.textContent = label; }, 1800);
        } finally {
          share.disabled = false;
        }
      });
    </script>
  </body>
</html>

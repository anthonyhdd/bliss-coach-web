  <script>
    function initFrenchGender() {
      const form = document.getElementById('gender-form') as HTMLFormElement | null;
      const quiz = document.getElementById('quiz');
      if (!form && !quiz) return;
      // Guard against double-binding across ClientRouter navigations
      if ((form as any)?.__fgBound) return;
      if (form) (form as any).__fgBound = true;

      // ---------- Verified dictionary of common French nouns ----------
      // g: 'm' | 'f'  ·  en: English  ·  rule: the ending rule / note
      type Noun = { fr: string; g: 'm' | 'f'; en: string; rule: string };
      const DICT: Noun[] = [
        // Feminine — -tion / -sion / -son
        { fr: 'nation', g: 'f', en: 'nation', rule: '-tion endings are feminine.' },
        { fr: 'question', g: 'f', en: 'question', rule: '-tion endings are feminine.' },
        { fr: 'solution', g: 'f', en: 'solution', rule: '-tion endings are feminine.' },
        { fr: 'situation', g: 'f', en: 'situation', rule: '-tion endings are feminine.' },
        { fr: 'décision', g: 'f', en: 'decision', rule: '-sion endings are feminine.' },
        { fr: 'télévision', g: 'f', en: 'television', rule: '-sion endings are feminine.' },
        { fr: 'maison', g: 'f', en: 'house', rule: '-son endings are usually feminine.' },
        { fr: 'raison', g: 'f', en: 'reason', rule: '-son endings are usually feminine.' },
        { fr: 'saison', g: 'f', en: 'season', rule: '-son endings are usually feminine.' },
        { fr: 'chanson', g: 'f', en: 'song', rule: '-son endings are usually feminine.' },
        { fr: 'boisson', g: 'f', en: 'drink', rule: '-son endings are usually feminine.' },
        { fr: 'leçon', g: 'f', en: 'lesson', rule: '-çon here is feminine (unlike most -on nouns).' },
        // Feminine — -té / -tié
        { fr: 'liberté', g: 'f', en: 'freedom', rule: '-té endings are feminine.' },
        { fr: 'beauté', g: 'f', en: 'beauty', rule: '-té endings are feminine.' },
        { fr: 'santé', g: 'f', en: 'health', rule: '-té endings are feminine.' },
        { fr: 'société', g: 'f', en: 'society', rule: '-té endings are feminine.' },
        { fr: 'vérité', g: 'f', en: 'truth', rule: '-té endings are feminine.' },
        { fr: 'université', g: 'f', en: 'university', rule: '-té endings are feminine.' },
        { fr: 'amitié', g: 'f', en: 'friendship', rule: '-tié endings are feminine.' },
        // Feminine — -ée
        { fr: 'journée', g: 'f', en: 'day', rule: '-ée endings are feminine.' },
        { fr: 'idée', g: 'f', en: 'idea', rule: '-ée endings are feminine.' },
        { fr: 'année', g: 'f', en: 'year', rule: '-ée endings are feminine.' },
        { fr: 'pensée', g: 'f', en: 'thought', rule: '-ée endings are feminine.' },
        { fr: 'soirée', g: 'f', en: 'evening', rule: '-ée endings are feminine.' },
        // Feminine — -ette
        { fr: 'fourchette', g: 'f', en: 'fork', rule: '-ette endings are feminine.' },
        { fr: 'baguette', g: 'f', en: 'baguette', rule: '-ette endings are feminine.' },
        { fr: 'assiette', g: 'f', en: 'plate', rule: '-ette endings are feminine.' },
        { fr: 'chaussette', g: 'f', en: 'sock', rule: '-ette endings are feminine.' },
        // Feminine — -ance / -ence
        { fr: 'chance', g: 'f', en: 'luck', rule: '-ance endings are feminine.' },
        { fr: 'distance', g: 'f', en: 'distance', rule: '-ance endings are feminine.' },
        { fr: 'science', g: 'f', en: 'science', rule: '-ence endings are feminine.' },
        { fr: 'patience', g: 'f', en: 'patience', rule: '-ence endings are feminine.' },
        { fr: 'différence', g: 'f', en: 'difference', rule: '-ence endings are feminine.' },
        // Feminine — -ure
        { fr: 'voiture', g: 'f', en: 'car', rule: '-ure endings are feminine.' },
        { fr: 'nature', g: 'f', en: 'nature', rule: '-ure endings are feminine.' },
        { fr: 'peinture', g: 'f', en: 'painting', rule: '-ure endings are feminine.' },
        { fr: 'ceinture', g: 'f', en: 'belt', rule: '-ure endings are feminine.' },
        { fr: 'culture', g: 'f', en: 'culture', rule: '-ure endings are feminine.' },
        // Feminine — -ie
        { fr: 'vie', g: 'f', en: 'life', rule: '-ie endings are feminine.' },
        { fr: 'boulangerie', g: 'f', en: 'bakery', rule: '-ie endings are feminine.' },
        { fr: 'pharmacie', g: 'f', en: 'pharmacy', rule: '-ie endings are feminine.' },
        { fr: 'partie', g: 'f', en: 'part', rule: '-ie endings are feminine.' },
        { fr: 'sortie', g: 'f', en: 'exit', rule: '-ie endings are feminine.' },
        // Feminine — -esse / -ade
        { fr: 'vitesse', g: 'f', en: 'speed', rule: '-esse endings are feminine.' },
        { fr: 'richesse', g: 'f', en: 'wealth', rule: '-esse endings are feminine.' },
        { fr: 'promesse', g: 'f', en: 'promise', rule: '-esse endings are feminine.' },
        { fr: 'salade', g: 'f', en: 'salad', rule: '-ade endings are feminine.' },
        { fr: 'limonade', g: 'f', en: 'lemonade', rule: '-ade endings are feminine.' },
        // Feminine — -age / -eau exceptions
        { fr: 'plage', g: 'f', en: 'beach', rule: 'Exception: -age is usually masculine, but la plage is feminine.' },
        { fr: 'page', g: 'f', en: 'page', rule: 'Exception: -age is usually masculine, but la page is feminine.' },
        { fr: 'cage', g: 'f', en: 'cage', rule: 'Exception: -age is usually masculine, but la cage is feminine.' },
        { fr: 'image', g: 'f', en: 'image', rule: 'Exception: -age is usually masculine, but l\'image is feminine.' },
        { fr: 'eau', g: 'f', en: 'water', rule: 'Exception: -eau is usually masculine, but l\'eau is feminine.' },
        { fr: 'peau', g: 'f', en: 'skin', rule: 'Exception: -eau is usually masculine, but la peau is feminine.' },
        // Feminine — -eur (abstract) & others
        { fr: 'peur', g: 'f', en: 'fear', rule: 'Abstract -eur nouns like la peur are feminine.' },
        { fr: 'couleur', g: 'f', en: 'colour', rule: 'Abstract -eur nouns like la couleur are feminine.' },
        { fr: 'fleur', g: 'f', en: 'flower', rule: 'Abstract -eur nouns like la fleur are feminine.' },
        { fr: 'valeur', g: 'f', en: 'value', rule: 'Abstract -eur nouns like la valeur are feminine.' },
        { fr: 'chaleur', g: 'f', en: 'heat', rule: 'Abstract -eur nouns like la chaleur are feminine.' },
        { fr: 'main', g: 'f', en: 'hand', rule: 'Exception: -in is usually masculine, but la main is feminine.' },
        { fr: 'fin', g: 'f', en: 'end', rule: 'Exception: -in is usually masculine, but la fin is feminine.' },
        { fr: 'mer', g: 'f', en: 'sea', rule: 'Exception: -er is usually masculine, but la mer is feminine.' },
        { fr: 'table', g: 'f', en: 'table', rule: 'Learn this common noun as la table.' },
        { fr: 'porte', g: 'f', en: 'door', rule: 'Learn this common noun as la porte.' },
        { fr: 'fenêtre', g: 'f', en: 'window', rule: 'Learn this common noun as la fenêtre.' },
        { fr: 'chaise', g: 'f', en: 'chair', rule: 'Learn this common noun as la chaise.' },
        { fr: 'fille', g: 'f', en: 'girl / daughter', rule: '-ille endings are feminine; also natural gender.' },
        { fr: 'femme', g: 'f', en: 'woman', rule: 'Natural gender: la femme is feminine.' },
        { fr: 'ville', g: 'f', en: 'city', rule: 'Learn this common noun as la ville.' },
        { fr: 'nuit', g: 'f', en: 'night', rule: 'Learn this common noun as la nuit.' },
        { fr: 'clé', g: 'f', en: 'key', rule: 'Learn this common noun as la clé.' },
        { fr: 'voix', g: 'f', en: 'voice', rule: 'Learn this common noun as la voix.' },
        { fr: 'faim', g: 'f', en: 'hunger', rule: 'Learn this common noun as la faim.' },
        // Masculine — -age
        { fr: 'fromage', g: 'm', en: 'cheese', rule: '-age endings are masculine.' },
        { fr: 'voyage', g: 'm', en: 'trip', rule: '-age endings are masculine.' },
        { fr: 'garage', g: 'm', en: 'garage', rule: '-age endings are masculine.' },
        { fr: 'message', g: 'm', en: 'message', rule: '-age endings are masculine.' },
        { fr: 'village', g: 'm', en: 'village', rule: '-age endings are masculine.' },
        { fr: 'nuage', g: 'm', en: 'cloud', rule: '-age endings are masculine.' },
        { fr: 'courage', g: 'm', en: 'courage', rule: '-age endings are masculine.' },
        // Masculine — -ment
        { fr: 'gouvernement', g: 'm', en: 'government', rule: '-ment endings are masculine.' },
        { fr: 'moment', g: 'm', en: 'moment', rule: '-ment endings are masculine.' },
        { fr: 'appartement', g: 'm', en: 'apartment', rule: '-ment endings are masculine.' },
        { fr: 'vêtement', g: 'm', en: 'garment', rule: '-ment endings are masculine.' },
        { fr: 'document', g: 'm', en: 'document', rule: '-ment endings are masculine.' },
        // Masculine — -eau
        { fr: 'bureau', g: 'm', en: 'office / desk', rule: '-eau endings are masculine.' },
        { fr: 'château', g: 'm', en: 'castle', rule: '-eau endings are masculine.' },
        { fr: 'gâteau', g: 'm', en: 'cake', rule: '-eau endings are masculine.' },
        { fr: 'cadeau', g: 'm', en: 'gift', rule: '-eau endings are masculine.' },
        { fr: 'couteau', g: 'm', en: 'knife', rule: '-eau endings are masculine.' },
        { fr: 'manteau', g: 'm', en: 'coat', rule: '-eau endings are masculine.' },
        { fr: 'chapeau', g: 'm', en: 'hat', rule: '-eau endings are masculine.' },
        // Masculine — -isme
        { fr: 'tourisme', g: 'm', en: 'tourism', rule: '-isme endings are masculine.' },
        { fr: 'organisme', g: 'm', en: 'organism', rule: '-isme endings are masculine.' },
        // Masculine — -ail / -eil / -euil
        { fr: 'travail', g: 'm', en: 'work', rule: '-ail endings are masculine.' },
        { fr: 'soleil', g: 'm', en: 'sun', rule: '-eil endings are masculine.' },
        { fr: 'réveil', g: 'm', en: 'alarm clock', rule: '-eil endings are masculine.' },
        { fr: 'fauteuil', g: 'm', en: 'armchair', rule: '-euil endings are masculine.' },
        // Masculine — -in / -oir / -ain
        { fr: 'vin', g: 'm', en: 'wine', rule: '-in endings are masculine.' },
        { fr: 'jardin', g: 'm', en: 'garden', rule: '-in endings are masculine.' },
        { fr: 'matin', g: 'm', en: 'morning', rule: '-in endings are masculine.' },
        { fr: 'magasin', g: 'm', en: 'shop', rule: '-in endings are masculine.' },
        { fr: 'pain', g: 'm', en: 'bread', rule: '-ain endings are masculine.' },
        { fr: 'train', g: 'm', en: 'train', rule: '-ain endings are masculine.' },
        { fr: 'miroir', g: 'm', en: 'mirror', rule: '-oir endings are masculine.' },
        { fr: 'soir', g: 'm', en: 'evening', rule: '-oir endings are masculine.' },
        { fr: 'devoir', g: 'm', en: 'duty / homework', rule: '-oir endings are masculine.' },
        { fr: 'couloir', g: 'm', en: 'hallway', rule: '-oir endings are masculine.' },
        // Masculine — -eur (people & machines) + exceptions
        { fr: 'ordinateur', g: 'm', en: 'computer', rule: '-eur for machines is masculine.' },
        { fr: 'moteur', g: 'm', en: 'engine', rule: '-eur for machines is masculine.' },
        { fr: 'professeur', g: 'm', en: 'teacher', rule: '-eur for people/roles is masculine.' },
        { fr: 'bonheur', g: 'm', en: 'happiness', rule: 'Exception: le bonheur is masculine despite the -eur ending.' },
        // Masculine — -on / misc
        { fr: 'poisson', g: 'm', en: 'fish', rule: '-on endings are usually masculine.' },
        { fr: 'garçon', g: 'm', en: 'boy', rule: '-on endings are usually masculine; also natural gender.' },
        { fr: 'camion', g: 'm', en: 'truck', rule: '-on endings are usually masculine.' },
        { fr: 'avion', g: 'm', en: 'plane', rule: '-on endings are usually masculine.' },
        { fr: 'livre', g: 'm', en: 'book', rule: 'Learn this common noun as le livre.' },
        { fr: 'stylo', g: 'm', en: 'pen', rule: 'Learn this common noun as le stylo.' },
        { fr: 'café', g: 'm', en: 'coffee / café', rule: 'Learn this common noun as le café.' },
        { fr: 'musée', g: 'm', en: 'museum', rule: 'Exception: le musée is masculine despite the -ée ending.' },
        { fr: 'lycée', g: 'm', en: 'high school', rule: 'Exception: le lycée is masculine despite the -ée ending.' },
        { fr: 'problème', g: 'm', en: 'problem', rule: '-ème endings are masculine.' },
        { fr: 'système', g: 'm', en: 'system', rule: '-ème endings are masculine.' },
        { fr: 'téléphone', g: 'm', en: 'telephone', rule: 'Learn this common noun as le téléphone.' },
        { fr: 'jour', g: 'm', en: 'day', rule: 'Learn this common noun as le jour.' },
        { fr: 'temps', g: 'm', en: 'time / weather', rule: 'Learn this common noun as le temps.' },
        { fr: 'homme', g: 'm', en: 'man', rule: 'Natural gender: l\'homme is masculine.' },
        { fr: 'argent', g: 'm', en: 'money / silver', rule: 'Learn this common noun as l\'argent.' },
        { fr: 'chien', g: 'm', en: 'dog', rule: 'Learn this common noun as le chien.' },
        { fr: 'chat', g: 'm', en: 'cat', rule: 'Learn this common noun as le chat.' },
      ];

      // Strip accents + lower-case for matching so "decision" finds "décision"
      const norm = (s: string) =>
        (s || '')
          .toLowerCase()
          .normalize('NFD')
          .replace(/[̀-ͯ]/g, '')
          .replace(/^(le |la |l'|un |une |les |des )/, '')
          .replace(/[^a-z]/g, '')
          .trim();

      const byNorm = new Map<string, Noun>();
      DICT.forEach((n) => byNorm.set(norm(n.fr), n));

      const startsVowel = (w: string) => /^[aeiouhàâäéèêëïîôùûü]/i.test(w);
      const defArticle = (n: { g: 'm' | 'f'; fr: string }) =>
        startsVowel(n.fr) ? "l'" + n.fr : (n.g === 'm' ? 'le ' : 'la ') + n.fr;
      const indef = (g: 'm' | 'f') => (g === 'm' ? 'un' : 'une');

      // Heuristic guesser for words NOT in the dictionary (labelled as a guess)
      function guess(word: string): { g: 'm' | 'f'; rule: string } | null {
        const w = norm(word);
        if (!w) return null;
        // feminine endings
        if (/(tion|sion|té|tié|ette|ance|ence|ure|esse|ade)$/.test(word.toLowerCase())) return { g: 'f', rule: 'This ending is typically feminine.' };
        if (/(tion|sion|tte|ance|ence|ure|esse|ade)$/.test(w)) return { g: 'f', rule: 'This ending is typically feminine.' };
        // masculine endings
        if (/(ment|isme|eau|ail|eil|euil|oir)$/.test(w)) return { g: 'm', rule: 'This ending is typically masculine.' };
        if (/age$/.test(w)) return { g: 'm', rule: '-age endings are typically masculine (watch: la plage, la page).' };
        if (/(ee|tie)$/.test(w)) return { g: 'f', rule: 'This ending is typically feminine.' };
        if (/ie$/.test(w)) return { g: 'f', rule: '-ie endings are typically feminine.' };
        if (/eur$/.test(w)) return { g: 'm', rule: '-eur is mixed: masculine for people/machines, feminine for many abstract nouns — verify this one.' };
        return null;
      }

      /* ---------- Checker ---------- */
      const input = document.getElementById('noun-input') as HTMLInputElement | null;
      const resultBox = document.getElementById('gender-result') as HTMLElement | null;
      const datalist = document.getElementById('noun-list') as HTMLElement | null;
      const picksBox = document.getElementById('quick-picks') as HTMLElement | null;

      if (datalist) {
        datalist.innerHTML = '';
        DICT.slice().sort((a, b) => a.fr.localeCompare(b.fr, 'fr')).forEach((n) => {
          const opt = document.createElement('option');
          opt.value = n.fr;
          datalist.appendChild(opt);
        });
      }

      function showResult(query: string) {
        if (!resultBox) return;
        const key = norm(query);
        if (!key) { resultBox.hidden = true; return; }
        const hit = byNorm.get(key);
        resultBox.classList.remove('fem', 'masc');
        if (hit) {
          const isF = hit.g === 'f';
          resultBox.classList.add(isF ? 'fem' : 'masc');
          resultBox.innerHTML =
            '<p class="gr-article"><b>' + defArticle(hit) + '</b></p>' +
            '<p class="gr-gender">' + (isF ? 'Feminine' : 'Masculine') + ' · ' + indef(hit.g) + ' ' + hit.fr + '</p>' +
            '<p class="gr-en">English: <b>' + hit.en + '</b></p>' +
            '<p class="gr-why"><em>Why:</em> ' + hit.rule + '</p>';
          resultBox.hidden = false;
          return;
        }
        // Not in dictionary — offer an honest heuristic guess
        const g = guess(query);
        if (g) {
          const isF = g.g === 'f';
          resultBox.classList.add(isF ? 'fem' : 'masc');
          resultBox.innerHTML =
            '<p class="gr-article"><b>' + (isF ? 'la ' : 'le ') + query.trim().toLowerCase() + '</b> ?</p>' +
            '<p class="gr-gender">Likely ' + (isF ? 'feminine' : 'masculine') + '</p>' +
            '<p class="gr-why"><em>Best guess:</em> ' + g.rule + '</p>' +
            '<p class="gr-guess">⚠ This word isn\'t in our checked list — it\'s an ending-based guess, so confirm it in a dictionary.</p>';
          resultBox.hidden = false;
          return;
        }
        resultBox.classList.add('masc');
        resultBox.innerHTML =
          '<p class="gr-article">Not found</p>' +
          '<p class="gr-why">We don\'t have <b>' + query.trim() + '</b> in the checked list and its ending doesn\'t match a clear rule. Try one of the common nouns below, or learn this one with its article from a dictionary.</p>';
        resultBox.hidden = false;
      }

      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          if (input) showResult(input.value);
        });
      }

      if (picksBox) {
        const picks = ['table', 'fromage', 'décision', 'voyage', 'liberté', 'bureau', 'plage', 'eau', 'question', 'soleil', 'couleur', 'jardin'];
        picksBox.innerHTML = '';
        picks.forEach((p) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'pick-chip';
          b.textContent = p;
          b.addEventListener('click', () => {
            if (input) input.value = p;
            showResult(p);
            resultBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
          picksBox.appendChild(b);
        });
      }

      /* ---------- Practice quiz ---------- */
      if (!quiz) return;
      // 20 nouns with a clear rule, drawn from the verified dictionary.
      type Q = { fr: string; g: 'm' | 'f'; en: string; why: string };
      const BANK: Q[] = [
        { fr: 'décision', g: 'f', en: 'decision', why: '-tion / -sion endings are feminine.' },
        { fr: 'fromage', g: 'm', en: 'cheese', why: '-age endings are masculine.' },
        { fr: 'liberté', g: 'f', en: 'freedom', why: '-té endings are feminine.' },
        { fr: 'bureau', g: 'm', en: 'office / desk', why: '-eau endings are masculine.' },
        { fr: 'voiture', g: 'f', en: 'car', why: '-ure endings are feminine.' },
        { fr: 'gouvernement', g: 'm', en: 'government', why: '-ment endings are masculine.' },
        { fr: 'journée', g: 'f', en: 'day', why: '-ée endings are feminine.' },
        { fr: 'travail', g: 'm', en: 'work', why: '-ail endings are masculine.' },
        { fr: 'chance', g: 'f', en: 'luck', why: '-ance / -ence endings are feminine.' },
        { fr: 'tourisme', g: 'm', en: 'tourism', why: '-isme endings are masculine.' },
        { fr: 'fourchette', g: 'f', en: 'fork', why: '-ette endings are feminine.' },
        { fr: 'soleil', g: 'm', en: 'sun', why: '-eil endings are masculine.' },
        { fr: 'boulangerie', g: 'f', en: 'bakery', why: '-ie endings are feminine.' },
        { fr: 'jardin', g: 'm', en: 'garden', why: '-in endings are masculine.' },
        { fr: 'plage', g: 'f', en: 'beach', why: 'Exception: -age is usually masculine, but la plage is feminine.' },
        { fr: 'musée', g: 'm', en: 'museum', why: 'Exception: -ée is usually feminine, but le musée is masculine.' },
        { fr: 'couleur', g: 'f', en: 'colour', why: 'Abstract -eur nouns like la couleur are feminine.' },
        { fr: 'miroir', g: 'm', en: 'mirror', why: '-oir endings are masculine.' },
        { fr: 'eau', g: 'f', en: 'water', why: 'Exception: -eau is usually masculine, but l\'eau is feminine.' },
        { fr: 'question', g: 'f', en: 'question', why: '-tion endings are feminine.' },
      ];

      const $ = (id: string) => document.getElementById(id);
      const sentenceEl = $('q-sentence') as HTMLElement;
      const enEl = $('q-en') as HTMLElement;
      const optionsEl = $('q-options') as HTMLElement;
      const feedbackEl = $('q-feedback') as HTMLElement;
      const nextBtn = $('q-next') as HTMLButtonElement;
      const progressEl = $('q-progress') as HTMLElement;
      const scoreEl = $('q-score') as HTMLElement;
      const summaryEl = $('quiz-summary') as HTMLElement;
      const quizCard = $('quiz') as HTMLElement;

      let order: number[] = [];
      let pos = 0;
      let correct = 0;
      let answered = 0;
      let locked = false;

      function shuffle(n: number) {
        const a = Array.from({ length: n }, (_, i) => i);
        for (let i = a.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [a[i], a[j]] = [a[j], a[i]];
        }
        return a;
      }

      function updateMeta() {
        progressEl.textContent = 'Question ' + Math.min(pos + 1, BANK.length) + ' of ' + BANK.length;
        scoreEl.textContent = 'Score ' + correct + '/' + answered;
      }

      function render() {
        const item = BANK[order[pos]];
        locked = false;
        feedbackEl.hidden = true;
        feedbackEl.className = 'q-feedback';
        feedbackEl.innerHTML = '';
        nextBtn.hidden = true;
        nextBtn.textContent = pos === BANK.length - 1 ? 'See results →' : 'Next →';

        sentenceEl.innerHTML = '<span class="blank">___</span> ' + item.fr;
        enEl.textContent = 'the ' + item.en;

        optionsEl.innerHTML = '';
        for (const art of ['le', 'la'] as const) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'q-opt';
          btn.innerHTML = '<span class="form">' + art + '</span>';
          btn.addEventListener('click', () => choose(btn, art, item));
          optionsEl.appendChild(btn);
        }
        updateMeta();
      }

      function choose(btn: HTMLButtonElement, art: 'le' | 'la', item: Q) {
        if (locked) return;
        locked = true;
        answered++;
        const correctArt = item.g === 'm' ? 'le' : 'la';
        const isRight = art === correctArt;
        const opts = Array.prototype.slice.call(optionsEl.querySelectorAll('.q-opt')) as HTMLButtonElement[];
        opts.forEach((o) => {
          o.disabled = true;
          const v = (o.querySelector('.form') as HTMLElement).textContent;
          if (v === correctArt) o.classList.add('correct');
          else if (o === btn) o.classList.add('wrong');
        });
        // display form (l' before a vowel)
        const disp = startsVowel(item.fr) ? "l'" + item.fr : correctArt + ' ' + item.fr;
        if (isRight) {
          correct++;
          feedbackEl.className = 'q-feedback good';
          feedbackEl.innerHTML = '✓ Correct — <b>' + disp + '</b> (' + item.en + '). ' + item.why;
        } else {
          feedbackEl.className = 'q-feedback bad';
          feedbackEl.innerHTML = '✗ It\'s <b>' + disp + '</b> (' + item.en + '). ' + item.why;
        }
        feedbackEl.hidden = false;
        nextBtn.hidden = false;
        updateMeta();
      }

      function finish() {
        quizCard.hidden = true;
        summaryEl.hidden = false;
        const pct = Math.round((correct / BANK.length) * 100);
        const title = $('qs-title') as HTMLElement;
        const line = $('qs-line') as HTMLElement;
        if (pct >= 90) title.textContent = 'Parfait ! ' + correct + '/' + BANK.length;
        else if (pct >= 70) title.textContent = 'Très bien ! ' + correct + '/' + BANK.length;
        else if (pct >= 50) title.textContent = 'Good start — ' + correct + '/' + BANK.length;
        else title.textContent = 'Keep practising — ' + correct + '/' + BANK.length;
        line.textContent = 'You got ' + correct + ' of ' + BANK.length + ' right (' + pct + '%). Review the ending rules above, then reshuffle for a fresh round.';
        progressEl.textContent = 'Done · ' + BANK.length + ' of ' + BANK.length;
        scoreEl.textContent = 'Score ' + correct + '/' + BANK.length;
      }

      function start() {
        order = shuffle(BANK.length);
        pos = 0; correct = 0; answered = 0;
        quizCard.hidden = false;
        summaryEl.hidden = true;
        render();
      }

      nextBtn.addEventListener('click', () => {
        if (pos >= BANK.length - 1) { finish(); return; }
        pos++;
        render();
      });
      $('q-restart')?.addEventListener('click', start);
      $('q-shuffle')?.addEventListener('click', start);

      start();
    }

    document.addEventListener('astro:page-load', initFrenchGender);
  </script>
</Base>

---
import Base from '../../../layouts/Base.astro';
import { APPS, withBase } from '../../../config/apps';

const app = APPS.amelie;
const brandStyle = `--brand-1:${app.gradient[0]};--brand-2:${app.gradient[1]};--brand-3:${app.gradient[2]};--accent:${app.accent};--on-gradient:${app.onGradient}`;

const pageTitle = 'French Noun Gender Checker (le/la)';
const pageDescription =
  'Is it le or la, un or une? Check 110+ common French nouns, learn the reliable ending rules, and practice with an instant-feedback quiz. Free, no signup.';
const canonicalUrl = 'https://bliss-coach.com/amelie/tools/french-gender/';

const faqs = [
  {
    q: 'How do I know if a French noun is le or la?',
    a: 'There is no way to tell from meaning alone — gender is a property of the word, so the safest habit is to learn every noun with its article (say "la table", never just "table"). That said, the word ending is a strong clue. Endings like -tion, -té, -ée, -ette, -ance and -ure are almost always feminine (la), while -age, -ment, -eau, -isme and -eil are almost always masculine (le). This tool checks 110+ common nouns for you and shows the rule behind each one.',
  },
  {
    q: 'Which French endings are feminine?',
    a: 'The most reliable feminine endings are -tion / -sion (la nation, la décision), -té (la liberté), -ée (la journée), -ette (la fourchette), -ance / -ence (la chance, la science), -ure (la voiture) and -ie (la vie). They hold the vast majority of the time. Watch a few masculine exceptions: le musée and le lycée end in -ée, and le silence ends in -ence.',
  },
  {
    q: 'Which French endings are masculine?',
    a: 'The most reliable masculine endings are -age (le fromage), -ment (le gouvernement), -eau (le bureau), -isme (le tourisme), -ail / -eil / -euil (le travail, le soleil, le fauteuil) and -oir (le miroir). The classic exceptions to learn: la plage, la page, la cage and l\'image end in -age but are feminine, and l\'eau and la peau end in -eau but are feminine.',
  },
  {
    q: 'Does un / une follow the same rule as le / la?',
    a: 'Yes. French gender is one property of the noun, so the same word takes le and un when masculine (le livre, un livre) and la and une when feminine (la table, une table). Learn the gender once and every article — le/la, un/une, ce/cette, mon/ma — falls into place. Before a vowel or silent h, le and la both shorten to l\' (l\'ami, l\'eau), which hides the gender, so those words are especially worth memorising with un or une.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'French Noun Gender Checker & Practice',
    applicationCategory: 'EducationalApplication',
    operatingSystem: 'Web',
    url: canonicalUrl,
    description: pageDescription,
    isAccessibleForFree: true,
    inLanguage: 'en',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    publisher: { '@type': 'Organization', name: 'Bliss Coach', url: 'https://bliss-coach.com/' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Bliss Coach', item: 'https://bliss-coach.com/' },
      { '@type': 'ListItem', position: 2, name: 'Amélie', item: 'https://bliss-coach.com/amelie/' },
      { '@type': 'ListItem', position: 3, name: 'French Noun Gender', item: canonicalUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---

<Base
  title={pageTitle}
  description={pageDescription}
  appStoreId={app.appStoreId}
  ogImage={`/icons/${app.slug}.jpg`}
  bodyClass="article-page"
  activeApp={app.slug}
  soloHeader={{ slug: app.slug, name: app.name, appStoreUrl: app.appStoreUrl }}
  brandStyle={brandStyle}
  jsonLd={jsonLd}
>
  <div style={brandStyle}>
    <div class="brand-strip" aria-hidden="true"></div>

    <header class="article-header">
      <div class="article-hero-tint" aria-hidden="true"></div>
      <a class="app-chip" href={withBase('/amelie/')}>
        <img src={withBase(`/icons/${app.slug}.jpg`)} alt="" width="24" height="24" />
        {app.name} · {app.category}
      </a>
      <span class="crumb"><a href={withBase('/amelie/')}>Learn French</a> · Free tool</span>
      <h1>French Noun Gender Checker — le or la?</h1>
      <p class="meta">Every French noun is masculine or feminine, and the article (le/la, un/une) has to match. Learn the reliable ending rules, check any of 110+ common nouns, then drill 20 with instant feedback. Everything runs in your browser.</p>
    </header>

    <!-- Intro (also visible without JS) -->
    <div class="prose tool-intro">
      <p>
        The single biggest headache in French grammar is <strong>noun gender</strong>: is it
        <strong>le</strong> or <strong>la</strong>, <strong>un</strong> or <strong>une</strong>? Gender is baked
        into each word, so the golden habit is to always learn a noun <em>with</em> its article — say
        <em>"la table"</em>, never just <em>"table"</em>. But you're not flying blind: the
        <strong>ending</strong> of a noun predicts its gender most of the time. Learn the patterns below, use the
        checker when you're stuck, and practise until <em>le</em> and <em>la</em> feel automatic.
      </p>
    </div>

    <!-- RULES cheat-sheet (pure HTML, always visible) -->
    <section class="rules" aria-label="French gender ending rules">
      <div class="rule-card fem">
        <div class="rc-head">
          <span class="rc-verb">Usually LA</span>
          <span class="rc-tag">feminine endings</span>
        </div>
        <ul>
          <li><b>-tion / -sion</b> · <span class="ex">la na<u>tion</u>, la déci<u>sion</u></span></li>
          <li><b>-té / -tié</b> · <span class="ex">la liber<u>té</u>, l'ami<u>tié</u></span> <span class="exc">except le côté, l'été</span></li>
          <li><b>-ée</b> · <span class="ex">la journ<u>ée</u>, l'id<u>ée</u></span> <span class="exc">except le musée, le lycée</span></li>
          <li><b>-ette</b> · <span class="ex">la fourch<u>ette</u>, la bagu<u>ette</u></span></li>
          <li><b>-ance / -ence</b> · <span class="ex">la ch<u>ance</u>, la sci<u>ence</u></span> <span class="exc">except le silence</span></li>
          <li><b>-ure</b> · <span class="ex">la voit<u>ure</u>, la nat<u>ure</u></span></li>
          <li><b>-ie</b> · <span class="ex">la v<u>ie</u>, la boulanger<u>ie</u></span> <span class="exc">except le génie, l'incendie</span></li>
        </ul>
      </div>

      <div class="rule-card masc">
        <div class="rc-head">
          <span class="rc-verb">Usually LE</span>
          <span class="rc-tag">masculine endings</span>
        </div>
        <ul>
          <li><b>-age</b> · <span class="ex">le from<u>age</u>, le voy<u>age</u></span> <span class="exc">except la plage, la page, l'image</span></li>
          <li><b>-ment</b> · <span class="ex">le gouverne<u>ment</u>, le mo<u>ment</u></span></li>
          <li><b>-eau</b> · <span class="ex">le bur<u>eau</u>, le chât<u>eau</u></span> <span class="exc">except l'eau, la peau</span></li>
          <li><b>-isme</b> · <span class="ex">le tour<u>isme</u>, le cap<u>italisme</u></span></li>
          <li><b>-ail / -eil / -euil</b> · <span class="ex">le trav<u>ail</u>, le sol<u>eil</u></span></li>
          <li><b>-in / -oir</b> · <span class="ex">le v<u>in</u>, le mir<u>oir</u></span> <span class="exc">except la main, la fin</span></li>
          <li><b>-eur (people &amp; machines)</b> · <span class="ex">le mot<u>eur</u>, le profess<u>eur</u></span> <span class="exc">but la peur, la couleur</span></li>
        </ul>
      </div>
    </section>

    <!-- CHECKER -->
    <section class="tool checker" aria-label="French noun gender checker">
      <h2 class="tool-h2">Check a noun's gender</h2>
      <p class="tool-lead">Type a French noun (or pick one below) to get its article — <em>le/la</em> and <em>un/une</em> — plus the ending rule behind it.</p>

      <form id="gender-form" class="gender-form" novalidate>
        <label class="visually-hidden" for="noun-input">French noun</label>
        <input id="noun-input" name="noun" type="text" autocomplete="off" spellcheck="false"
          list="noun-list" placeholder="e.g. table, fromage, décision…" />
        <button type="submit" class="tbtn tbtn-brand">Check</button>
      </form>
      <datalist id="noun-list"></datalist>

      <div class="quick-picks" id="quick-picks" aria-label="Common nouns"></div>

      <div id="gender-result" class="gender-result" hidden aria-live="polite"></div>

      <noscript>
        <p class="noscript-note">
          This checker needs JavaScript. Without it, use the two rule cards above: match your noun's ending to a
          pattern. Endings like <strong>-tion, -té, -ée, -ette, -ance, -ure, -ie</strong> are almost always
          feminine (<strong>la</strong>); endings like <strong>-age, -ment, -eau, -isme, -eil</strong> are almost
          always masculine (<strong>le</strong>).
        </p>
      </noscript>
    </section>

    <!-- PRACTICE quiz -->
    <section class="tool practice" aria-label="French gender practice quiz">
      <div class="quiz-head">
        <h2 class="tool-h2">Practice: le or la?</h2>
        <div class="quiz-meta">
          <span id="q-progress" class="stat-pill">Question 1 of 20</span>
          <span id="q-score" class="stat-pill">Score 0/0</span>
        </div>
      </div>

      <div id="quiz" class="quiz-card">
        <p id="q-sentence" class="q-sentence">Loading…</p>
        <p id="q-en" class="q-en"></p>
        <div id="q-options" class="q-options"></div>
        <div id="q-feedback" class="q-feedback" hidden aria-live="polite"></div>
        <div class="q-buttons">
          <button type="button" id="q-next" class="tbtn tbtn-brand" hidden>Next →</button>
        </div>
      </div>

      <div id="quiz-summary" class="quiz-summary" hidden>
        <h3 id="qs-title">Bravo !</h3>
        <p id="qs-line"></p>
        <button type="button" id="q-restart" class="tbtn tbtn-brand">Try again (reshuffle)</button>
      </div>

      <div class="tool-actions-top" style="margin-top:14px">
        <button type="button" id="q-shuffle" class="tbtn tbtn-ghost">Shuffle &amp; restart</button>
      </div>

      <noscript>
        <p class="noscript-note">
          The practice quiz needs JavaScript. Three worked examples to study meanwhile:
          <br />• <strong>la décision</strong> — feminine, because -tion / -sion endings are feminine.
          <br />• <strong>le fromage</strong> — masculine, because -age endings are masculine.
          <br />• <strong>la liberté</strong> — feminine, because -té endings are feminine.
        </p>
      </noscript>
    </section>

    <!-- SEO / teaching content -->
    <div class="prose tool-explainer">
      <h2>Why French gender feels random (and how to beat it)</h2>
      <p>
        A table isn't "more feminine" than a book — grammatical gender has nothing to do with meaning. It's a
        label attached to each noun, and the only way to be fully sure is to learn the article with the word.
        The good news: French spelling is regular enough that the <strong>last few letters</strong> of a noun
        predict its gender correctly around 80–90% of the time, which is exactly what the rules above capture.
      </p>

      <h2>The exceptions worth memorising</h2>
      <ul>
        <li><strong>-age is masculine, but</strong> <em>la plage, la page, la cage, l'image, la nage</em> and <em>la rage</em> are feminine.</li>
        <li><strong>-eau is masculine, but</strong> <em>l'eau</em> (water) and <em>la peau</em> (skin) are feminine.</li>
        <li><strong>-ée is feminine, but</strong> <em>le musée, le lycée</em> and <em>le trophée</em> are masculine.</li>
        <li><strong>-eur splits:</strong> people and machines are masculine (<em>le professeur, le moteur</em>), but many abstract nouns are feminine (<em>la peur, la couleur, la fleur, la valeur</em>). Note <em>le bonheur</em> and <em>l'honneur</em> stay masculine.</li>
        <li><strong>Before a vowel or silent h,</strong> both <em>le</em> and <em>la</em> shrink to <em>l'</em> (<em>l'ami, l'eau</em>), hiding the gender — learn those nouns with <em>un</em> or <em>une</em> instead.</li>
      </ul>

      <h2>Frequently asked questions</h2>
      {faqs.map((f) => (
        <>
          <h3>{f.q}</h3>
          <p>{f.a}</p>
        </>
      ))}
    </div>

    <!-- Internal links -->
    <section class="section container" style="padding-top:8px">
      <div class="tool-links">
        <a class="article-card" href={withBase('/amelie/how-to-say/')}>
          <h3>How to say it in French →</h3>
          <p>Phrase-by-phrase guides: natural translations, pronunciation, and real example conversations.</p>
          <span class="read">Browse phrases →</span>
        </a>
        <a class="article-card" href={withBase('/amelie/')}>
          <h3>Meet Amélie →</h3>
          <p>Your witty AI French teacher from Paris — practise le and la out loud in real voice conversations.</p>
          <span class="read">See the app →</span>
        </a>
      </div>
    </section>

    <!-- Secondary CTA -->
    <aside class="cta-box">
      <div class="inner">
        <img src={withBase(`/icons/${app.slug}.jpg`)} alt="Amélie app icon" width="72" height="72" />
        <div>
          <h3>Make le vs la automatic — talk it out with Amélie</h3>
          <p>Gender sticks when you use it out loud. Amélie is an AI French teacher from Paris who chats with you, corrects your articles in real time, and adapts to your level — free to try on iPhone.</p>
        </div>
        <a class="btn" href={app.appStoreUrl}>Get Amélie free</a>
      </div>
    </aside>
  </div>

  <style>
    /* Inherits the light "article-page" theme + Amélie brand vars */
    .tool-intro { padding-bottom: 8px; }
    .tool {
      max-width: var(--prose-w);
      margin: 0 auto;
      padding: 8px 24px;
    }
    .tool-h2 { font-size: 22px; letter-spacing: -0.02em; color: #121216; margin: 0 0 6px; }
    .tool-lead { font-size: 15px; color: #6b6b76; margin: 0 0 16px; line-height: 1.5; }
    .tool-actions-top { display: flex; justify-content: flex-end; }
    .article-header .crumb a { color: var(--accent); }
    .visually-hidden {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    /* Rules cheat-sheet */
    .rules {
      max-width: var(--prose-w);
      margin: 8px auto 4px;
      padding: 8px 24px;
      display: grid; grid-template-columns: 1fr 1fr; gap: 18px;
    }
    @media (max-width: 640px) { .rules { grid-template-columns: 1fr; } }
    .rule-card {
      background: #fff;
      border: 1px solid rgba(0, 0, 0, 0.09);
      border-radius: 14px;
      padding: 18px 18px 16px;
    }
    .rule-card.fem { border-top: 3px solid var(--brand-2); }
    .rule-card.masc { border-top: 3px solid var(--brand-3); }
    .rc-head { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; margin-bottom: 12px; }
    .rc-verb { font-size: 20px; font-weight: 800; letter-spacing: 0.01em; color: #17171c; }
    .rule-card.fem .rc-verb { color: color-mix(in srgb, var(--brand-2) 82%, #17171c); }
    .rule-card.masc .rc-verb { color: color-mix(in srgb, var(--brand-3) 80%, #17171c); }
    .rc-tag { font-size: 12.5px; color: #8a8a94; font-weight: 600; }
    .rule-card ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
    .rule-card li { font-size: 14.5px; line-height: 1.5; color: #33333c; }
    .rule-card li b { color: #17171c; }
    .rule-card .ex { color: #6b6b76; }
    .rule-card .ex u { text-decoration: none; font-weight: 700; }
    .rule-card.fem .ex u { color: color-mix(in srgb, var(--brand-2) 76%, #17171c); }
    .rule-card.masc .ex u { color: color-mix(in srgb, var(--brand-3) 74%, #17171c); }
    .rule-card .exc { display: block; font-size: 12.5px; color: #a06a2c; margin-top: 2px; }

    /* Checker */
    .gender-form { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 14px; }
    #noun-input {
      flex: 1 1 260px; min-width: 0;
      font: inherit; font-size: 16px; color: #17171c;
      background: #fbfbfc;
      border: 1px solid rgba(0, 0, 0, 0.14); border-radius: 12px;
      padding: 12px 15px;
    }
    #noun-input:focus { outline: none; border-color: color-mix(in srgb, var(--accent) 55%, rgba(0,0,0,0.14)); box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 14%, transparent); }
    #noun-input::placeholder { color: #a6a6b0; }

    .quick-picks { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
    .pick-chip {
      font: inherit; font-size: 13.5px; font-weight: 600; cursor: pointer;
      background: #fff; border: 1px solid rgba(0, 0, 0, 0.13); color: #33333c;
      border-radius: 99px; padding: 7px 13px;
      transition: transform 0.12s, border-color 0.12s, background 0.12s;
    }
    .pick-chip:hover { transform: translateY(-1px); border-color: color-mix(in srgb, var(--accent) 55%, rgba(0,0,0,0.13)); }
    .pick-chip:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    .gender-result {
      margin-top: 16px;
      background: #fff; border: 1px solid rgba(0, 0, 0, 0.09);
      border-left: 3px solid var(--accent);
      border-radius: 12px; padding: 18px 20px;
    }
    .gender-result.fem { border-left-color: var(--brand-2); }
    .gender-result.masc { border-left-color: var(--brand-3); }
    .gr-article { font-size: 26px; font-weight: 800; letter-spacing: -0.01em; margin: 0 0 4px; color: #17171c; }
    .gender-result.fem .gr-article b { color: color-mix(in srgb, var(--brand-2) 78%, #17171c); }
    .gender-result.masc .gr-article b { color: color-mix(in srgb, var(--brand-3) 74%, #17171c); }
    .gr-gender { font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #9a9aa4; margin: 0 0 10px; }
    .gr-en { font-size: 15px; color: #55555f; margin: 0 0 10px; }
    .gr-en b { color: #33333c; }
    .gr-why { font-size: 15px; line-height: 1.6; color: #33333c; margin: 0; background: #f6f6f9; border-radius: 9px; padding: 10px 14px; }
    .gr-why em { font-style: normal; font-weight: 700; }
    .gr-guess { font-size: 13px; color: #a06a2c; margin: 10px 0 0; }

    /* Practice quiz */
    .quiz-head { display: flex; align-items: baseline; justify-content: space-between; gap: 14px; flex-wrap: wrap; margin-bottom: 14px; }
    .quiz-meta { display: flex; gap: 8px; }
    .stat-pill {
      font-size: 13px; font-weight: 600; color: #55555f;
      background: #f1f1f5; border-radius: 99px; padding: 5px 12px;
    }
    .quiz-card {
      background: #fff; border: 1px solid rgba(0, 0, 0, 0.09);
      border-radius: 14px; padding: 22px 22px 18px;
    }
    .q-sentence { font-size: 24px; line-height: 1.4; color: #17171c; margin: 0 0 6px; letter-spacing: -0.01em; }
    .q-sentence .blank { color: var(--accent); font-weight: 800; }
    .q-en { font-size: 14.5px; color: #8a8a94; font-style: italic; margin: 0 0 18px; }
    .q-options { display: flex; gap: 12px; flex-wrap: wrap; }
    .q-opt {
      flex: 1 1 0; min-width: 130px;
      font: inherit; cursor: pointer; text-align: center;
      background: #fbfbfc; border: 1.5px solid rgba(0, 0, 0, 0.12); border-radius: 12px;
      padding: 14px 16px;
      transition: transform 0.12s, border-color 0.12s, box-shadow 0.12s, background 0.12s;
    }
    .q-opt:hover:not(:disabled) { transform: translateY(-2px); border-color: color-mix(in srgb, var(--accent) 55%, rgba(0,0,0,0.12)); }
    .q-opt:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .q-opt .form { display: block; font-size: 22px; font-weight: 800; color: #17171c; }
    .q-opt:disabled { cursor: default; }
    .q-opt.correct { background: color-mix(in srgb, #16a34a 12%, #fff); border-color: #16a34a; }
    .q-opt.correct .form { color: #15683a; }
    .q-opt.wrong { background: color-mix(in srgb, #dc2626 10%, #fff); border-color: #dc2626; }
    .q-opt.wrong .form { color: #b4231b; }

    .q-feedback {
      margin-top: 16px; border-radius: 11px; padding: 12px 15px;
      font-size: 14.5px; line-height: 1.55;
    }
    .q-feedback.good { background: color-mix(in srgb, #16a34a 12%, #fff); color: #15683a; border: 1px solid color-mix(in srgb, #16a34a 24%, transparent); }
    .q-feedback.bad { background: color-mix(in srgb, #f59e0b 13%, #fff); color: #8a5a08; border: 1px solid color-mix(in srgb, #f59e0b 30%, transparent); }
    .q-feedback b { font-weight: 800; }
    .q-buttons { margin-top: 16px; display: flex; justify-content: flex-end; }

    .quiz-summary {
      background: #fff; border: 1px solid rgba(0, 0, 0, 0.09);
      border-left: 3px solid var(--accent);
      border-radius: 14px; padding: 22px; text-align: center;
    }
    .quiz-summary h3 { font-size: 24px; margin: 0 0 6px; color: #121216; }
    .quiz-summary p { font-size: 16px; color: #55555f; margin: 0 0 16px; }

    .tbtn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 22px; border-radius: 99px;
      font: inherit; font-weight: 700; font-size: 15px; cursor: pointer;
      border: 1px solid transparent;
      transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
    }
    .tbtn-brand {
      background: linear-gradient(92deg, var(--brand-1), var(--brand-2), var(--brand-3));
      color: var(--on-gradient);
      box-shadow: 0 8px 26px color-mix(in srgb, var(--accent) 32%, transparent);
    }
    .tbtn-brand:hover { transform: translateY(-2px); box-shadow: 0 12px 34px color-mix(in srgb, var(--accent) 45%, transparent); }
    .tbtn-ghost { background: #fff; border-color: rgba(0, 0, 0, 0.14); color: #33333c; }
    .tbtn-ghost:hover { background: #f3f3f7; }
    .tbtn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    .noscript-note {
      margin: 16px 0 0;

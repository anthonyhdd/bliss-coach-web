---
import { withBase } from '../config/apps';

interface Props {
  /** app-scoped landing footer: quiet app identity, no cross-links */
  solo?: { name: string; slug?: string };
}
const { solo } = Astro.props;
const year = new Date().getFullYear();
---

{solo ? (
  <footer class="site-footer site-footer--solo">
    <div class="container">
      <div class="solo-id">
        {solo.slug && <img src={withBase(`/icons/${solo.slug}.jpg`)} alt="" width="22" height="22" loading="lazy" />}
        <span>{solo.name}</span>
        <i>·</i>
        <span class="solo-sub">a <a class="solo-home" href={withBase('/')}>Bliss Coach</a> app</span>
      </div>
      <nav class="links" aria-label="Legal">
        <a href="/privacy/" rel="nofollow">Privacy Policy</a>
        <a href="/terms/" rel="nofollow">Terms of Use</a>
        <span>© {year}</span>
      </nav>
    </div>
  </footer>
) : (
  <footer class="site-footer">
    <div class="container inner">
      <span>© {year} Bliss Coach — AI coaching apps</span>
      <nav class="links" aria-label="Legal">
        <a href="/privacy/" rel="nofollow">Privacy Policy</a>
        <a href="/terms/" rel="nofollow">Terms of Use</a>
        <a href="https://apps.apple.com/us/developer/bliss-coach/id1628409883">App Store</a>
      </nav>
    </div>
  </footer>
)}

---
import { withBase } from '../config/apps';

interface Props {
  /** app-scoped landing footer: quiet app identity, no cross-links */
  solo?: { name: string; slug?: string };
}
const { solo } = Astro.props;
const year = new Date().getFullYear();
---

{solo ? (
  <footer class="site-footer site-footer--solo">
    <div class="container">
      <div class="solo-id">
        {solo.slug && <img src={withBase(`/icons/${solo.slug}.jpg`)} alt="" width="22" height="22" loading="lazy" />}
        <span>{solo.name}</span>
        <i>·</i>
        <span class="solo-sub">a <a class="solo-home" href={withBase('/')}>Bliss Coach</a> app</span>
      </div>
      <nav class="links" aria-label="Legal">
        <a href="/privacy/" rel="nofollow">Privacy Policy</a>
        <a href="/terms/" rel="nofollow">Terms of Use</a>
        <span>© {year}</span>
      </nav>
    </div>
  </footer>
) : (
  <footer class="site-footer">
    <div class="container inner">
      <span>© {year} Bliss Coach — AI coaching apps</span>
      <nav class="links" aria-label="Legal">
        <a href="/privacy/" rel="nofollow">Privacy Policy</a>
        <a href="/terms/" rel="nofollow">Terms of Use</a>
        <a href="https://apps.apple.com/us/developer/bliss-coach/id1628409883">App Store</a>
      </nav>
    </div>
    {/* KAMO easter egg: the 3D figure hiding in the footer — peeks up on hover, links to the app */}
    <a
      class="kamo-peek"
      href="https://apps.apple.com/app/id6789639784"
      target="_blank"
      rel="noopener"
      aria-label="KAMO: Hide & Seek Photo Game on the App Store"
    >
      <img src={withBase('/kamo-peek.png')} alt="" width="66" height="160" loading="lazy" />
    </a>
  </footer>
)}

<style>
  .site-footer { position: relative; overflow: hidden; }
  .site-footer .container { position: relative; z-index: 1; }
  .kamo-peek {
    position: absolute;
    right: clamp(14px, 6vw, 72px);
    bottom: -82px;                  /* body sunk below the footer — only head/shoulders peek up */
    display: block;
    width: 66px;
    opacity: .8;
    z-index: 0;
    filter: drop-shadow(0 6px 16px rgba(0,0,0,.18));
    transition: transform .5s cubic-bezier(.2,.9,.3,1), opacity .35s ease;
  }
  .kamo-peek img { display: block; width: 100%; height: auto; }
  .site-footer:hover .kamo-peek { transform: translateY(-40px); opacity: 1; }  /* peekaboo */
  @media (max-width: 640px){ .kamo-peek { width: 52px; bottom: -66px; right: 12px; } }
  @media (prefers-reduced-motion: reduce){ .kamo-peek { transition: none; } }
</style>

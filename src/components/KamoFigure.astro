---
/*
 * KAMO easter egg — a real, draggable 3D figure hiding in the footer.
 * Same white mannequin + spring/squash physics as the KAMO app itself.
 * Three.js is lazy-loaded (dynamic import) only when the footer nears the
 * viewport, so it never weighs on first paint. Drag it, or tap it to pose.
 */
---

<canvas id="kamo3d" aria-hidden="true"></canvas>

<style>
  #kamo3d {
    position: absolute;
    left: clamp(10px, 6vw, 84px);
    bottom: 0;
    width: 210px;
    height: 300px;
    z-index: 1;               /* above the grid backdrop, below nothing it can block */
    cursor: grab;
    touch-action: none;       /* we own the drag gesture */
    -webkit-tap-highlight-color: transparent;
  }
  #kamo3d.grabbing { cursor: grabbing; }
  @media (max-width: 640px) {
    #kamo3d { width: 148px; height: 210px; left: 6px; }
  }
</style>

<script>
  const canvas = document.getElementById('kamo3d');
  if (canvas) {
    let started = false;
    // Lazy-boot when the footer nears the viewport. We don't rely on
    // IntersectionObserver alone: this site's smooth-scroll can suppress its
    // ticks, so we also poll getBoundingClientRect on capture-phase scroll.
    const footer = canvas.closest('footer') || canvas;
    const acts = ['scroll', 'wheel', 'touchmove'];
    let io = null;
    const cleanup = () => {
      acts.forEach((ev) => window.removeEventListener(ev, check, true));
      window.removeEventListener('resize', check);
      io && io.disconnect();
    };
    const boot = () => { if (started) return; started = true; cleanup(); init(); };
    const check = () => {
      const r = footer.getBoundingClientRect();
      if (r.top < window.innerHeight + 500 && r.bottom > -500) boot();
    };
    if ('IntersectionObserver' in window) {
      io = new IntersectionObserver((entries) => { if (entries.some((e) => e.isIntersecting)) boot(); }, { rootMargin: '500px' });
      io.observe(footer);
    }
    // capture phase so custom/smooth-scroll wrappers can't swallow the signal
    acts.forEach((ev) => window.addEventListener(ev, check, { capture: true, passive: true }));
    window.addEventListener('resize', check);
    check();
    // guaranteed fallback: boot during idle after load, so the figure is always
    // ready even where the scroll signal never reaches us (Three.js stays off
    // the critical path — it never blocks first paint).
    const idleBoot = () => (window.requestIdleCallback || ((f) => setTimeout(f, 1)))(boot, { timeout: 3000 });
    if (document.readyState === 'complete') setTimeout(idleBoot, 2500);
    else window.addEventListener('load', () => setTimeout(idleBoot, 2500));

    async function init() {
      let THREE;
      try {
        THREE = await import(/* @vite-ignore */ `${import.meta.env.BASE_URL}vendor/three.module.js`);
      } catch (_) { return; }

      const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      /* ---- renderer / scene / camera / light ---- */
      const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
      renderer.setPixelRatio(Math.min(2, window.devicePixelRatio || 1));
      renderer.outputColorSpace = THREE.SRGBColorSpace;
      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(40, 1, 0.1, 100);
      camera.position.set(0, 1.02, 4.35);
      camera.lookAt(0, 1.0, 0);
      scene.add(new THREE.HemisphereLight(0xffffff, 0x40404c, 1.2));
      const key = new THREE.DirectionalLight(0xffffff, 1.45); key.position.set(3, 5, 4); scene.add(key);
      const rim = new THREE.DirectionalLight(0xbfe3ff, 0.55); rim.position.set(-4, 2, -3); scene.add(rim);

      /* ---- character rig (from the KAMO app) ---- */
      const WHITE = () => new THREE.MeshStandardMaterial({ color: 0xf6f6f8, roughness: 0.82, metalness: 0 });
      const capsule = (r, len) => new THREE.Mesh(new THREE.CapsuleGeometry(r, len, 6, 16), WHITE());
      const pivot = (x, y, z) => { const g = new THREE.Group(); g.position.set(x, y, z); return g; };

      function blobShadow() {
        const c = document.createElement('canvas'); c.width = c.height = 128;
        const x = c.getContext('2d');
        const g = x.createRadialGradient(64, 64, 4, 64, 64, 62);
        g.addColorStop(0, 'rgba(0,0,0,.42)'); g.addColorStop(1, 'rgba(0,0,0,0)');
        x.fillStyle = g; x.fillRect(0, 0, 128, 128);
        const m = new THREE.Mesh(new THREE.PlaneGeometry(1.7, 1.7),
          new THREE.MeshBasicMaterial({ map: new THREE.CanvasTexture(c), transparent: true, depthWrite: false }));
        m.rotation.x = -Math.PI / 2; m.position.y = 0.01; return m;
      }

      const REST = { spine: [0, 0, 0], head: [0, 0, 0], shL: [0, 0, .14], shR: [0, 0, -.14], elL: [0, 0, 0], elR: [0, 0, 0], hipL: [0, 0, 0], hipR: [0, 0, 0], knL: [0, 0, 0], knR: [0, 0, 0], rootDY: 0 };
      const POSES = [
        { p: {} },                                                              // stand
        { p: { shR: [0, 0, -2.55], elR: [.7, 0, 0] } },                         // wave
        { p: { shL: [0, 0, 2.5], shR: [0, 0, -2.5] } },                         // arms up
        { p: { hipL: [-1.55, 0, .06], hipR: [-1.55, 0, -.06], knL: [1.6, 0, 0], knR: [1.6, 0, 0], shL: [.35, 0, .16], shR: [.35, 0, -.16], rootDY: -.42 } }, // sit
        { p: { shR: [-1.3, 0, -.12], elR: [.15, 0, 0] } },                      // point
      ];
      const fullPose = (i) => { const o = JSON.parse(JSON.stringify(REST)); const p = POSES[i].p; for (const k in p) o[k] = p[k]; return o; };

      const group = new THREE.Group(); scene.add(group);
      const charG = new THREE.Group(); group.add(charG);
      charG.add(blobShadow());
      const parts = {};
      const spine = pivot(0, 1.0, 0); charG.add(spine); parts.spine = spine;
      const torso = capsule(0.34, 0.62); torso.position.y = 0.36; spine.add(torso);
      const shoulders = pivot(0, 0.72, 0); spine.add(shoulders);
      const head = pivot(0, 0, 0); shoulders.add(head); parts.head = head;
      const headMesh = new THREE.Mesh(new THREE.SphereGeometry(0.32, 24, 20), WHITE()); headMesh.position.y = 0.34; head.add(headMesh);
      function arm(side) { const sh = pivot(0.30 * side, -0.02, 0); shoulders.add(sh); const up = capsule(0.145, 0.40); up.position.y = -0.24; sh.add(up); const el = pivot(0, -0.46, 0); sh.add(el); const lo = capsule(0.13, 0.38); lo.position.y = -0.23; el.add(lo); return { sh, el }; }
      const aL = arm(1), aR = arm(-1); parts.shL = aL.sh; parts.elL = aL.el; parts.shR = aR.sh; parts.elR = aR.el;
      function leg(side) { const hip = pivot(0.17 * side, 1.0, 0); charG.add(hip); const up = capsule(0.16, 0.44); up.position.y = -0.27; hip.add(up); const kn = pivot(0, -0.52, 0); hip.add(kn); const lo = capsule(0.145, 0.42); lo.position.y = -0.26; kn.add(lo); const foot = new THREE.Mesh(new THREE.SphereGeometry(0.15, 16, 12), WHITE()); foot.scale.set(1, .6, 1.5); foot.position.set(0, -0.5, 0.06); kn.add(foot); return { hip, kn }; }
      const lL = leg(1), lR = leg(-1); parts.hipL = lL.hip; parts.knL = lL.kn; parts.hipR = lR.hip; parts.knR = lR.kn;

      const meshes = []; charG.traverse((o) => { if (o.isMesh && o.geometry.type !== 'PlaneGeometry') meshes.push(o); });
      const char = { group, charG, parts, meshes, target: fullPose(0) };
      // instant rest pose
      for (const k in REST) { if (k === 'rootDY') { charG.position.y = char.target.rootDY; continue; } parts[k].rotation.set(char.target[k][0], char.target[k][1], char.target[k][2]); }

      /* ---- physics: momentum spring + squash&stretch + secondary sway ---- */
      function lerpChar(c) {
        const s = 0.18, g = c.group;
        if (c._svx === undefined) { c._svx = 0; c._svy = 0; }
        if (c._tx === undefined) { c._tx = g.position.x; c._ty = g.position.y; }
        c._svx = (c._svx + (c._tx - g.position.x) * 0.4) * 0.7;
        c._svy = (c._svy + (c._ty - g.position.y) * 0.4) * 0.7;
        g.position.x += c._svx; g.position.y += c._svy;
        const spd = Math.hypot(c._svx, c._svy), st = Math.min(0.32, spd * 5),
          hx = (Math.abs(c._svx) + 1e-4) / (Math.abs(c._svx) + Math.abs(c._svy) + 2e-4), cg = c.charG;
        cg.scale.x += ((1 + st * hx - st * (1 - hx) * 0.5) - cg.scale.x) * 0.3;
        cg.scale.y += ((1 + st * (1 - hx) - st * hx * 0.5) - cg.scale.y) * 0.3;
        const px = g.position.x; if (c._lx === undefined) c._lx = px;
        c._vx = (c._vx || 0) * 0.86 + (px - c._lx) * 0.16; c._lx = px;
        const v = Math.max(-0.9, Math.min(0.9, c._vx * 10));
        const sw = { spine: [0, 0, -v * 0.6], head: [0, 0, -v * 0.45], shL: [0, 0, -v * 1.1], shR: [0, 0, -v * 1.1], hipL: [v * 0.45, 0, 0], hipR: [-v * 0.45, 0, 0] };
        for (const k in REST) {
          if (k === 'rootDY') { cg.position.y += (c.target.rootDY - cg.position.y) * s; continue; }
          const r = c.parts[k].rotation, t = c.target[k], o = sw[k] || [0, 0, 0];
          r.x += ((t[0] + o[0]) - r.x) * s; r.y += ((t[1] + o[1]) - r.y) * s; r.z += ((t[2] + o[2]) - r.z) * s;
        }
      }

      /* ---- drag + tap-to-pose ---- */
      const ray = new THREE.Raycaster();
      const plane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
      const ndc = (cx, cy) => { const r = canvas.getBoundingClientRect(); return new THREE.Vector2(((cx - r.left) / r.width) * 2 - 1, -(((cy - r.top) / r.height) * 2 - 1)); };
      const screenToWorld = (cx, cy) => { ray.setFromCamera(ndc(cx, cy), camera); const pt = new THREE.Vector3(); plane.constant = 0; ray.ray.intersectPlane(plane, pt); return pt; };
      const pickChar = (cx, cy) => { ray.setFromCamera(ndc(cx, cy), camera); return ray.intersectObjects(meshes, false).length > 0; };
      const BX = 1.05, BY_MIN = -0.25, BY_MAX = 1.25;
      let active = false, moved = false, dragging = false, hit = false, downX = 0, downY = 0, dsw = null, dsp = null, poseIdx = 0;

      canvas.addEventListener('pointerdown', (e) => {
        canvas.setPointerCapture?.(e.pointerId);
        active = true; moved = false; dragging = false; downX = e.clientX; downY = e.clientY;
        hit = pickChar(e.clientX, e.clientY);
      });
      canvas.addEventListener('pointermove', (e) => {
        if (!active) return;
        if (!moved && Math.hypot(e.clientX - downX, e.clientY - downY) > 6) {
          moved = true;
          if (hit) { dragging = true; canvas.classList.add('grabbing'); dsw = screenToWorld(e.clientX, e.clientY); dsp = char.group.position.clone(); }
        }
        if (dragging) {
          const w = screenToWorld(e.clientX, e.clientY);
          char._tx = Math.max(-BX, Math.min(BX, dsp.x + (w.x - dsw.x)));
          char._ty = Math.max(BY_MIN, Math.min(BY_MAX, dsp.y + (w.y - dsw.y)));
        }
      });
      const end = (e) => {
        if (!active) return;
        canvas.releasePointerCapture?.(e.pointerId);
        canvas.classList.remove('grabbing');
        if (!moved && hit) { poseIdx = (poseIdx + 1) % POSES.length; char.target = fullPose(poseIdx); }
        active = false; dragging = false; hit = false;
      };
      canvas.addEventListener('pointerup', end);
      canvas.addEventListener('pointercancel', end);

      /* ---- sizing + loop (paused when off-screen) ---- */
      function resize() {
        const w = canvas.clientWidth, h = canvas.clientHeight;
        if (!w || !h) return;
        renderer.setSize(w, h, false); camera.aspect = w / h; camera.updateProjectionMatrix();
      }
      resize();
      if ('ResizeObserver' in window) new ResizeObserver(resize).observe(canvas);

      let running = true, raf = 0;
      function loop() {
        raf = requestAnimationFrame(loop);
        lerpChar(char);
        if (!reduced) { const t = performance.now() / 1000; charG.rotation.z = Math.sin(t * 0.8) * 0.015; charG.rotation.y = Math.sin(t * 0.5) * 0.06; }
        renderer.render(scene, camera);
      }
      const vis = new IntersectionObserver((es) => {
        const on = es.some((e) => e.isIntersecting);
        if (on && !running) { running = true; loop(); }
        else if (!on && running) { running = false; cancelAnimationFrame(raf); }
      }, { rootMargin: '100px' });
      vis.observe(canvas);
      loop();
    }
  }
</script>
